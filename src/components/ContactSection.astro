---
import Section from './Section.astro';

interface Props {
  title: string;
  subtitle?: string;
  phoneLabel?: string;
  hoursLabel?: string;
  openingHours?: string[];
  ctaText: string;
  ctaLink: string;
  phoneNumber?: string;
  variant?: 'cards' | 'button' | 'minimal';
  background?: 'base' | 'cream' | 'paper' | 'surface' | 'dark';
  id?: string;
}

const {
  title,
  subtitle,
  phoneLabel = 'Telefon',
  hoursLabel = 'Öffnungszeiten',
  openingHours = [],
  ctaText,
  ctaLink,
  phoneNumber = '07361-73688',
  variant = 'cards',
  background = 'base',
  id = 'contact',
} = Astro.props;
---

{variant === 'cards' && (
  <Section id={id} title={title} background={background}>
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
        {/* Phone Card */}
        <div class="group bg-paper p-8 lg:p-10 shadow-subtle hover:shadow-soft transition-all duration-500 text-center">
          <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-secondary-100 flex items-center justify-center group-hover:bg-secondary-200 transition-colors duration-300">
            <svg class="w-7 h-7 text-secondary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
          </div>
          <h3 class="font-display text-xl font-semibold text-dark mb-3">{phoneLabel}</h3>
          <a href={`tel:${phoneNumber}`} class="text-primary-600 font-display text-xl hover:text-primary-700 transition-colors">
            {phoneNumber}
          </a>
        </div>
        
        {/* Hours Card */}
        <div class="group bg-paper p-8 lg:p-10 shadow-subtle hover:shadow-soft transition-all duration-500 text-center">
          <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-secondary-100 flex items-center justify-center group-hover:bg-secondary-200 transition-colors duration-300">
            <svg class="w-7 h-7 text-secondary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3 class="font-display text-xl font-semibold text-dark mb-3">{hoursLabel}</h3>
          <div class="font-body text-secondary space-y-1">
            {openingHours.map((line) => (
              <p>{line}</p>
            ))}
          </div>
        </div>
      </div>
      
      <div class="text-center">
        <a href={ctaLink} class="btn-primary">
          {ctaText}
        </a>
      </div>
    </div>
  </Section>
)}

{variant === 'button' && (
  <Section id={id} title={title} subtitle={subtitle} background={background} padding="medium">
    <div class="flex flex-wrap justify-center gap-4">
      <a href={ctaLink} class="btn-primary">
        {ctaText}
      </a>
    </div>
  </Section>
)}

{variant === 'minimal' && (
  <div id={id} class="text-center">
    <h3 class="font-display text-2xl font-semibold text-dark mb-4">{title}</h3>
    {subtitle && <p class="text-secondary mb-6">{subtitle}</p>}
    <a href={ctaLink} class="btn-primary">
      {ctaText}
    </a>
  </div>
)}
