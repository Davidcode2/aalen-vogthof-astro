---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';

const title = "Speisekarte - Menu | Vogthof Landgasthof";
const description = "Vogthof Landgasthof Menu / Speisekarte";
---

<Layout title={title} description={description}>
  <!-- Hero Section -->
  <Hero
    backgroundImage="/images/Aktionskalender.jpg"
    headline="Speisekarte"
    subheadline="Seasonal menu and calendar at Vogthof Landgasthof"
    ctaText="Download Menu"
    ctaLink="https://www.aalen-vogthof.de/aktionen/Aktionskalender.pdf"
    height="medium"
  />

  <!-- Menu Image Section -->
  <Section background="cream" padding="medium">
    <div class="flex flex-col items-center">
      <a 
        href="https://www.aalen-vogthof.de/aktionen/Aktionskalender.pdf" 
        target="_blank" 
        rel="noopener noreferrer"
        class="inline-block mb-6 group"
      >
        <img 
          src="/images/Aktionskalender.jpg" 
          alt="Menu Calendar"
          class="w-full max-w-2xl rounded-lg shadow-xl transition-transform duration-300 group-hover:scale-[1.02]"
        />
      </a>
      <p class="text-[#5C4033] font-['Open_Sans',Arial,sans-serif] text-center">
        Möchten Sie die Liste herunterladen, dann klicken Sie bitte auf das Bild.<br/>
        <span class="text-sm">(Click on the image to download the menu)</span>
      </p>
    </div>
  </Section>

  <!-- Seasonal Information Section -->
  <Section 
    title="Saisonale Highlights" 
    subtitle="Seasonal Highlights"
    background="old-lace"
    padding="medium"
  >
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="p-6 bg-white rounded-xl shadow-lg border border-[#8B4513]/10">
          <div class="flex items-center mb-4">
            <span class="text-3xl mr-3">🍃</span>
            <h4 class="font-['Playfair_Display',Georgia,serif] text-xl font-bold text-[#2C1810]">
              Frühlingsgerichte
            </h4>
          </div>
          <p class="font-['Open_Sans',Arial,sans-serif] text-[#5C4033]">
            Fresh spring dishes with seasonal vegetables and herbs.
          </p>
        </div>
        
        <div class="p-6 bg-white rounded-xl shadow-lg border border-[#8B4513]/10">
          <div class="flex items-center mb-4">
            <span class="text-3xl mr-3">☀️</span>
            <h4 class="font-['Playfair_Display',Georgia,serif] text-xl font-bold text-[#2C1810]">
              Sommerklassiker
            </h4>
          </div>
          <p class="font-['Open_Sans',Arial,sans-serif] text-[#5C4033]">
            Classic summer favorites with fresh, light ingredients.
          </p>
        </div>
        
        <div class="p-6 bg-white rounded-xl shadow-lg border border-[#8B4513]/10">
          <div class="flex items-center mb-4">
            <span class="text-3xl mr-3">🍂</span>
            <h4 class="font-['Playfair_Display',Georgia,serif] text-xl font-bold text-[#2C1810]">
              Herbstliche Spezialitäten
            </h4>
          </div>
          <p class="font-['Open_Sans',Arial,sans-serif] text-[#5C4033]">
            Autumn specialties with regional mushrooms and game.
          </p>
        </div>
        
        <div class="p-6 bg-white rounded-xl shadow-lg border border-[#8B4513]/10">
          <div class="flex items-center mb-4">
            <span class="text-3xl mr-3">❄️</span>
            <h4 class="font-['Playfair_Display',Georgia,serif] text-xl font-bold text-[#2C1810]">
              Wintergenüsse
            </h4>
          </div>
          <p class="font-['Open_Sans',Arial,sans-serif] text-[#5C4033]">
            Comforting winter dishes with seasonal ingredients.
          </p>
        </div>
      </div>
    </div>
  </Section>

  <!-- Opening Hours Section -->
  <Section 
    title="Öffnungszeiten" 
    subtitle="Opening Hours"
    background="antique"
    padding="medium"
    id="hours"
  >
    <div class="max-w-3xl mx-auto">
      <div class="overflow-x-auto">
        <table class="w-full min-w-[300px] text-left">
          <thead>
            <tr class="border-b border-[#8B4513]/30">
              <th class="py-4 px-4 font-['Playfair_Display',Georgia,serif] text-[#2C1810] text-lg">Day</th>
              <th class="py-4 px-4 font-['Playfair_Display',Georgia,serif] text-[#2C1810] text-lg">Time</th>
            </tr>
          </thead>
          <tbody class="font-['Open_Sans',Arial,sans-serif]">
            <tr class="border-b border-[#8B4513]/10">
              <td class="py-3 px-4 text-[#2C1810]">Montag-Donnerstag</td>
              <td class="py-3 px-4 text-[#5C4033]">11:30-14 Uhr</td>
            </tr>
            <tr class="border-b border-[#8B4513]/10">
              <td class="py-3 px-4 text-[#2C1810]">Montag-Mittwoch</td>
              <td class="py-3 px-4 text-[#5C4033]">18:00-22 Uhr</td>
            </tr>
            <tr class="border-b border-[#8B4513]/10">
              <td class="py-3 px-4 text-[#2C1810]">Freitag</td>
              <td class="py-3 px-4 text-[#8B4513] font-semibold">Ruhetag (Closed)</td>
            </tr>
            <tr class="border-b border-[#8B4513]/10">
              <td class="py-3 px-4 text-[#2C1810]">Samstag</td>
              <td class="py-3 px-4 text-[#5C4033]">18:00-22 Uhr</td>
            </tr>
            <tr class="border-b border-[#8B4513]/10">
              <td class="py-3 px-4 text-[#2C1810]">Sonntag</td>
              <td class="py-3 px-4 text-[#5C4033]">11:30-14 Uhr</td>
            </tr>
          </tbody>
        </table>
      </div>
      
      <div class="mt-6 p-4 bg-[#8B4513]/10 rounded-lg">
        <p class="font-['Open_Sans',Arial,sans-serif] text-[#5C4033] text-center">
          <strong class="text-[#2C1810]">Sonn- und Feiertage Abends geschlossen!</strong><br/>
          <span class="text-sm italic">(Sunday and public holidays evenings closed!)</span>
        </p>
      </div>
      
      <p class="mt-4 text-center font-['Open_Sans',Arial,sans-serif] text-[#8B4513] text-sm">
        Änderungen vorbehalten <span class="italic">(Subject to changes)</span>
      </p>
    </div>
  </Section>

  <!-- Closed Dates Section -->
  <Section background="cream" padding="medium">
    <div class="max-w-2xl mx-auto text-center">
      <h3 class="font-['Playfair_Display',Georgia,serif] text-2xl font-bold text-[#2C1810] mb-4">
        Geschlossen / Closed
      </h3>
      <div class="p-6 bg-[#8B4513]/15 rounded-lg">
        <p class="font-['Open_Sans',Arial,sans-serif] text-[#2C1810] text-lg">
          Dienstag 31.03. abends- und Mittwoch 01.04. bis einschließlich 05.04.2026 geschlossen.
        </p>
      </div>
    </div>
  </Section>

  <!-- Contact Section -->
  <Section background="white" padding="large">
    <div class="text-center max-w-2xl mx-auto">
      <h3 class="font-['Playfair_Display',Georgia,serif] text-3xl font-bold text-[#2C1810] mb-6">
        Kontakt / Contact
      </h3>
      <div class="p-8 bg-[#FFF8F0] rounded-xl shadow-lg border border-[#8B4513]/20">
        <p class="font-['Open_Sans',Arial,sans-serif] text-[#5C4033] text-xl">
          <strong class="text-[#2C1810]">Telefon:</strong> 07361-73688
        </p>
      </div>
    </div>
  </Section>

  <!-- Quick Links Section -->
  <Section background="old-lace" padding="medium">
    <div class="flex flex-wrap justify-center gap-6">
      <a 
        href="/tagesessen" 
        class="inline-block px-6 py-3 bg-[#8B4513] hover:bg-[#A0522D] text-white font-semibold rounded-md transition-all duration-300 shadow-lg hover:shadow-xl"
      >
        → Tagesessen (Daily Specials)
      </a>
      <a 
        href="/impressum" 
        class="inline-block px-6 py-3 border-2 border-[#8B4513] hover:bg-[#8B4513] hover:text-white text-[#8B4513] font-semibold rounded-md transition-all duration-300"
      >
        → Impressum (Legal)
      </a>
      <a 
        href="/datenschutz" 
        class="inline-block px-6 py-3 border-2 border-[#8B4513] hover:bg-[#8B4513] hover:text-white text-[#8B4513] font-semibold rounded-md transition-all duration-300"
      >
        → Datenschutz (Privacy)
      </a>
    </div>
  </Section>
</Layout>