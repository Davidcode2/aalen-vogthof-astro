---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Section from '../../components/Section.astro';
import { getTranslations } from '../../i18n/translations';

const locale = 'en';
const t = getTranslations(locale);

const seasons = [
  { key: 'spring', icon: '🍃' },
  { key: 'summer', icon: '☀️' },
  { key: 'autumn', icon: '🍂' },
  { key: 'winter', icon: '❄️' },
] as const;
---

<Layout 
  title="Menu | Vogthof Landgasthof"
  description="Seasonal menu and calendar at Vogthof Landgasthof"
  locale={locale}
>
  <Hero
    backgroundImage="/images/Aktionskalender.jpg"
    headline={t.aktionskalender.hero.headline}
    subheadline={t.aktionskalender.hero.subheadline}
    ctaText={t.aktionskalender.hero.cta}
    ctaLink="https://www.aalen-vogthof.de/aktionen/Aktionskalender.pdf"
    height="medium"
  />

  <Section background="background" padding="medium">
    <div class="flex flex-col items-center">
      <a href="https://www.aalen-vogthof.de/aktionen/Aktionskalender.pdf" target="_blank" rel="noopener noreferrer" class="inline-block mb-6 group">
        <img src="/images/Aktionskalender.jpg" alt="Menu" class="w-full max-w-2xl rounded-lg shadow-xl transition-transform duration-300 group-hover:scale-[1.02]" />
      </a>
      <p class="text-[#5C4033] font-['Open_Sans',Arial,sans-serif] text-center">{t.aktionskalender.download.text}</p>
    </div>
  </Section>

  <Section title={t.aktionskalender.seasonal.title} background="background-secondary" padding="medium">
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {seasons.map((season) => (
          <div class="p-6 bg-white rounded-xl shadow-lg border border-[#8B4513]/10">
            <div class="flex items-center mb-4">
              <span class="text-3xl mr-3">{season.icon}</span>
              <h4 class="font-['Playfair_Display',Georgia,serif] text-xl font-bold text-[#2C1810]">{t.aktionskalender.seasonal[season.key].title}</h4>
            </div>
            <p class="font-['Open_Sans',Arial,sans-serif] text-[#5C4033]">{t.aktionskalender.seasonal[season.key].description}</p>
          </div>
        ))}
      </div>
    </div>
  </Section>

  <Section title={t.aktionskalender.hours.title} background="surface" padding="medium" id="hours">
    <div class="max-w-3xl mx-auto">
      <div class="overflow-x-auto">
        <table class="w-full min-w-[300px] text-left">
          <thead>
            <tr class="border-b border-[#8B4513]/30">
              <th class="py-4 px-4 font-['Playfair_Display',Georgia,serif] text-[#2C1810] text-lg">Day</th>
              <th class="py-4 px-4 font-['Playfair_Display',Georgia,serif] text-[#2C1810] text-lg">Time</th>
            </tr>
          </thead>
          <tbody class="font-['Open_Sans',Arial,sans-serif]">
            {t.aktionskalender.hours.days.map((day) => (
              <tr class="border-b border-[#8B4513]/10">
                <td class="py-3 px-4 text-[#2C1810]">{day.day}</td>
                <td class="py-3 px-4 text-[#5C4033]">{day.time}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <div class="mt-6 p-4 bg-[#8B4513]/10 rounded-lg">
        <p class="font-['Open_Sans',Arial,sans-serif] text-[#5C4033] text-center">
          <strong class="text-[#2C1810]">{t.aktionskalender.hours.note}</strong>
        </p>
      </div>
      <p class="mt-4 text-center font-['Open_Sans',Arial,sans-serif] text-[#8B4513] text-sm">{t.aktionskalender.hours.subjectToChange}</p>
    </div>
  </Section>

  <Section background="background" padding="medium">
    <div class="max-w-2xl mx-auto text-center">
      <h3 class="font-['Playfair_Display',Georgia,serif] text-2xl font-bold text-[#2C1810] mb-4">{t.aktionskalender.closed.title}</h3>
      <div class="p-6 bg-[#8B4513]/15 rounded-lg">
        <p class="font-['Open_Sans',Arial,sans-serif] text-[#2C1810] text-lg">{t.aktionskalender.closed.text}</p>
      </div>
    </div>
  </Section>

  <Section background="white" padding="large">
    <div class="text-center max-w-2xl mx-auto">
      <h3 class="font-['Playfair_Display',Georgia,serif] text-3xl font-bold text-[#2C1810] mb-6">{t.aktionskalender.contact.title}</h3>
      <div class="p-8 bg-[#FFF8F0] rounded-xl shadow-lg border border-[#8B4513]/20">
        <p class="font-['Open_Sans',Arial,sans-serif] text-[#5C4033] text-xl"><strong class="text-[#2C1810]">{t.aktionskalender.contact.phone}</strong></p>
      </div>
    </div>
  </Section>

  <Section background="background-secondary" padding="medium">
    <div class="flex flex-wrap justify-center gap-6">
      <a href="/en/tagesessen" class="inline-block px-6 py-3 bg-[#8B4513] hover:bg-[#A0522D] text-white font-semibold rounded-md transition-all duration-300 shadow-lg hover:shadow-xl">
        → {t.aktionskalender.links.daily}
      </a>
      <a href="/en/impressum" class="inline-block px-6 py-3 border-2 border-[#8B4513] hover:bg-[#8B4513] hover:text-white text-[#8B4513] font-semibold rounded-md transition-all duration-300">
        → {t.aktionskalender.links.imprint}
      </a>
      <a href="/en/datenschutz" class="inline-block px-6 py-3 border-2 border-[#8B4513] hover:bg-[#8B4513] hover:text-white text-[#8B4513] font-semibold rounded-md transition-all duration-300">
        → {t.aktionskalender.links.privacy}
      </a>
    </div>
  </Section>
</Layout>
