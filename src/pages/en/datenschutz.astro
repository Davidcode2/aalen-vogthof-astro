---
import Layout from '../../layouts/Layout.astro';
import Section from '../../components/Section.astro';
import { getTranslations } from '../../i18n/translations';

const locale = 'en';
const t = getTranslations(locale);

const contactInfo = {
  owner: 'Reiner Ilg',
  address: 'Bergbaustraße 28/1, 73433 Aalen-Röthardt',
  email: 'info@aalen-vogthof.de',
  phone: '+49(0)7361 73688',
};
---

<Layout 
  title="Privacy Policy | Vogthof Landgasthof"
  description="Privacy policy of Vogthof Landgasthof. Information on the processing of personal data."
  locale={locale}
>
  <Section background="antique" padding="medium">
    <div class="text-center">
      <h1 class="font-['Playfair_Display',Georgia,serif] text-4xl md:text-5xl lg:text-6xl font-bold text-[#2C1810] mb-4">{t.datenschutz.hero.title}</h1>
      <p class="font-['Open_Sans',Arial,sans-serif] text-lg text-[#5C4033] max-w-2xl mx-auto">{t.datenschutz.hero.subtitle}</p>
    </div>
  </Section>

  <Section background="cream" padding="large">
    <div class="max-w-4xl mx-auto space-y-8">
      <div class="bg-white rounded-xl shadow-lg p-8">
        <h2 class="font-['Playfair_Display',Georgia,serif] text-2xl font-bold text-[#2C1810] mb-6">{t.datenschutz.sections.responsible.title}</h2>
        <p class="font-['Open_Sans',Arial,sans-serif] text-[#5C4033] mb-4">{t.datenschutz.sections.responsible.text}</p>
        <div class="space-y-3 pl-4 border-l-4 border-[#D4A574]">
          <p class="font-['Open_Sans',Arial,sans-serif] text-lg text-[#2C1810] font-semibold">{contactInfo.owner}</p>
          <p class="font-['Open_Sans',Arial,sans-serif] text-[#5C4033]">{contactInfo.address}</p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
            <div>
              <p class="font-['Open_Sans',Arial,sans-serif] text-sm text-[#5C4033]">Email:</p>
              <a href={`mailto:${contactInfo.email}`} class="font-['Open_Sans',Arial,sans-serif] text-[#8B4513] hover:text-[#2D5A27]">{contactInfo.email}</a>
            </div>
            <div>
              <p class="font-['Open_Sans',Arial,sans-serif] text-sm text-[#5C4033]">Phone:</p>
              <a href={`tel:${contactInfo.phone.replace(/\D/g, '')}`} class="font-['Open_Sans',Arial,sans-serif] text-[#8B4513] hover:text-[#2D5A27]">{contactInfo.phone}</a>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-lg p-8">
        <h2 class="font-['Playfair_Display',Georgia,serif] text-2xl font-bold text-[#2C1810] mb-6">{t.datenschutz.sections.scope.title}</h2>
        <p class="font-['Open_Sans',Arial,sans-serif] text-[#5C4033] leading-relaxed">{t.datenschutz.sections.scope.text}</p>
      </div>

      <div class="bg-white rounded-xl shadow-lg p-8">
        <h2 class="font-['Playfair_Display',Georgia,serif] text-2xl font-bold text-[#2C1810] mb-6">{t.datenschutz.sections.sharing.title}</h2>
        <p class="font-['Open_Sans',Arial,sans-serif] text-[#5C4033] leading-relaxed">{t.datenschutz.sections.sharing.text}</p>
      </div>

      <div class="bg-white rounded-xl shadow-lg p-8">
        <h2 class="font-['Playfair_Display',Georgia,serif] text-2xl font-bold text-[#2C1810] mb-6">{t.datenschutz.sections.cookies.title}</h2>
        <p class="font-['Open_Sans',Arial,sans-serif] text-[#5C4033] leading-relaxed">{t.datenschutz.sections.cookies.text}</p>
      </div>

      <div class="bg-white rounded-xl shadow-lg p-8">
        <h2 class="font-['Playfair_Display',Georgia,serif] text-2xl font-bold text-[#2C1810] mb-6">{t.datenschutz.sections.maps.title}</h2>
        <p class="font-['Open_Sans',Arial,sans-serif] text-[#5C4033] leading-relaxed">{t.datenschutz.sections.maps.text}</p>
      </div>

      <div class="bg-white rounded-xl shadow-lg p-8">
        <h2 class="font-['Playfair_Display',Georgia,serif] text-2xl font-bold text-[#2C1810] mb-6">{t.datenschutz.sections.rights.title}</h2>
        <p class="font-['Open_Sans',Arial,sans-serif] text-[#5C4033] leading-relaxed">{t.datenschutz.sections.rights.text}</p>
      </div>

      <div class="bg-white rounded-xl shadow-lg p-8">
        <h2 class="font-['Playfair_Display',Georgia,serif] text-2xl font-bold text-[#2C1810] mb-6">{t.datenschutz.sections.update.title}</h2>
        <p class="font-['Open_Sans',Arial,sans-serif] text-[#5C4033] leading-relaxed">{t.datenschutz.sections.update.text}</p>
      </div>

      <div class="flex flex-wrap justify-center gap-4">
        <a href="/en/contact" class="inline-flex items-center gap-2 px-6 py-3 bg-[#8B4513] hover:bg-[#2D5A27] text-white font-semibold rounded-lg shadow-lg hover:shadow-xl transition-all duration-300">{t.common.nav.contact}</a>
        <a href="/en/impressum" class="inline-flex items-center gap-2 px-6 py-3 border-2 border-[#8B4513] text-[#8B4513] hover:bg-[#8B4513] hover:text-white font-semibold rounded-lg transition-all duration-300">{t.common.footer.imprint}</a>
      </div>
    </div>
  </Section>
</Layout>
