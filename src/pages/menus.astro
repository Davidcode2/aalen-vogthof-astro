---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
import { getTranslations } from '../i18n/translations';

const locale = 'de';
const t = getTranslations(locale);

const heroImage = '/images/eat/mushroom_main_course.jpg';

const menuCategories = [
  { key: 'appetizers', icon: '🥗' },
  { key: 'mains', icon: '🍽️' },
  { key: 'desserts', icon: '🍰' },
  { key: 'drinks', icon: '🍷' },
] as const;
---

<Layout 
  title="Speisekarte | Vogthof Landgasthof"
  description="Frische, saisonale Zutaten mit Leidenschaft zubereitet."
  locale={locale}
>
  <!-- Hero Section -->
  <Hero
    headline={t.menus.hero.headline}
    subheadline={t.menus.hero.subheadline}
    backgroundImage={heroImage}
    ctaText={t.menus.hero.ctaPrimary}
    ctaLink="#daily-specials"
    ctaSecondaryText={t.menus.hero.ctaSecondary}
    ctaSecondaryLink="/restaurant"
    height="large"
  />

  <!-- Introduction from eat.md -->
  <Section
    title={t.menus.seasonal.title}
    subtitle={t.menus.seasonal.subtitle}
    background="background"
  >
    <div class="max-w-4xl mx-auto text-center">
      <blockquote class="text-xl italic text-secondary mb-8 font-serif">
        "{t.menus.seasonal.quote}"
        <cite class="block text-sm mt-2 not-italic">— {t.menus.seasonal.quoteAuthor}</cite>
      </blockquote>
      
      <div class="prose prose-lg text-secondary mx-auto">
        <p class="mb-6">
          {t.menus.seasonal.paragraph1}
        </p>
        <p class="mb-6">
          {t.menus.seasonal.paragraph2}
        </p>
        <p>
          {t.menus.seasonal.paragraph3}
        </p>
      </div>
    </div>
  </Section>

  <!-- Menu Categories Section -->
  <Section
    title={t.menus.categories.title}
    subtitle={t.menus.categories.subtitle}
    background="background-secondary"
  >
    <div class="grid md:grid-cols-2 gap-8">
      {menuCategories.map((category) => (
        <article class="bg-white rounded-lg p-8 shadow-md hover:shadow-lg transition-shadow">
          <div class="flex items-center mb-4">
            <span class="text-4xl mr-4">{category.icon}</span>
            <h3 class="font-display text-2xl font-bold text-primary">{t.menus.categories[category.key].name}</h3>
          </div>
          <p class="text-secondary mb-6">{t.menus.categories[category.key].description}</p>
          <ul class="space-y-3">
            {t.menus.categories[category.key].items.map((item) => (
              <li class="flex justify-between items-start border-b border-cream pb-2 last:border-0">
                <div>
                  <span class="font-semibold text-primary">{item.name}</span>
                  <p class="text-sm text-secondary">{item.desc}</p>
                </div>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </Section>

  <!-- Daily Specials Section -->
  <Section
    title={t.menus.dailySpecials.title}
    subtitle={t.menus.dailySpecials.availability}
    background="surface"
    id="daily-specials"
  >
    <div class="max-w-4xl mx-auto">
      <div class="bg-background rounded-lg p-8 mb-8">
        <div class="flex items-start gap-4 mb-6">
          <span class="text-5xl">🍽️</span>
          <div>
            <h3 class="font-display text-2xl font-bold text-primary">{t.menus.dailySpecials.title}</h3>
            <p class="text-secondary">{t.menus.dailySpecials.availability}</p>
          </div>
        </div>
        
        <div class="prose prose-lg text-secondary">
          <p class="mb-4">
            {t.menus.dailySpecials.description}
          </p>
          <ul class="list-disc list-inside space-y-2 mb-6">
            {t.menus.dailySpecials.includes.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
          <p>
            {t.menus.dailySpecials.cta}
          </p>
        </div>
      </div>
    </div>
  </Section>

  <!-- Allergen Information -->
  <Section
    title={t.menus.allergen.title}
    subtitle={t.menus.allergen.subtitle}
    background="background"
  >
    <div class="max-w-3xl mx-auto text-center">
      <div class="bg-white rounded-lg p-8 shadow-md mb-8">
        <p class="text-secondary text-lg mb-4">
          {t.menus.allergen.text1}
        </p>
        <p class="text-secondary">
          {t.menus.allergen.text2}
        </p>
      </div>
    </div>
  </Section>

  <!-- View Full Menu CTA -->
  <Section
    title={t.menus.cta.title}
    subtitle={t.menus.cta.subtitle}
    background="background-secondary"
  >
    <div class="text-center">
      <div class="flex flex-wrap justify-center gap-4 mb-8">
        <a
          href="/restaurant"
          class="inline-block px-8 py-4 bg-primary hover:bg-primary-light text-white font-semibold rounded-lg transition-all duration-300 shadow-lg hover:shadow-xl"
        >
          {t.menus.cta.ctaRestaurant}
        </a>
        <a
          href="tel:07361-73688"
          class="inline-block px-8 py-4 border-2 border-primary text-primary hover:bg-primary hover:text-white font-semibold rounded-lg transition-all duration-300"
        >
          {t.menus.cta.ctaCall}
        </a>
      </div>
      <p class="text-secondary">
        {t.menus.cta.hours}
      </p>
    </div>
  </Section>
</Layout>
