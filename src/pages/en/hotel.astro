---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Section from '../../components/Section.astro';
import Card from '../../components/Card.astro';
import ContactSection from '../../components/ContactSection.astro';
import { getTranslations } from '../../i18n/translations';

const locale = 'en';
const t = getTranslations(locale);

const amenities = [
  { key: 'rooms', icon: '🛏️' },
  { key: 'quality', icon: '⭐' },
  { key: 'location', icon: '🌿' },
  { key: 'dining', icon: '☕' },
  { key: 'wifi', icon: '📶' },
  { key: 'parking', icon: '🚗' },
] as const;
---

<Layout 
  title="Vogthof Landgasthof - Hotel"
  description="Your peaceful retreat in the countryside. Experience traditional hospitality with modern comfort."
  locale={locale}
>
  <Hero
    headline={t.hotel.hero.headline}
    subheadline={t.hotel.hero.subheadline}
    backgroundImage="/images/Datenschutz-header.jpg"
    ctaText={t.hotel.hero.ctaPrimary}
    ctaLink="/en/rooms"
    ctaSecondaryText={t.hotel.hero.ctaSecondary}
    ctaSecondaryLink="#contact"
    height="large"
  />

  <!-- Introduction Section -->
  <Section title={t.hotel.welcome.title} subtitle={t.hotel.welcome.subtitle}>
    <div class="max-w-3xl mx-auto text-center">
      <p class="font-['Open_Sans',Arial,sans-serif] text-lg text-[#5C4033] leading-relaxed mb-8">
        {t.hotel.welcome.paragraph1}
      </p>
      <p class="font-['Open_Sans',Arial,sans-serif] text-lg text-[#5C4033] leading-relaxed mb-8">
        {t.hotel.welcome.paragraph2}
      </p>
      <a
        href="/en/rooms"
        class="inline-block px-8 py-4 bg-[#8B4513] hover:bg-[#2D5A27] text-white font-semibold rounded-lg transition-colors duration-300 text-lg"
      >
        {t.hotel.welcome.cta}
      </a>
    </div>
  </Section>

  <!-- Amenities Grid -->
  <Section title={t.hotel.amenities.title} background="background-secondary">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {amenities.map((amenity) => (
        <Card
          title={`${amenity.icon} ${t.hotel.amenities.items[amenity.key].title}`}
          description={t.hotel.amenities.items[amenity.key].description}
        />
      ))}
    </div>
  </Section>

  <!-- Location Section -->
  <Section title={t.hotel.location.title} subtitle={t.hotel.location.subtitle} background="surface">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
      <div class="space-y-8">
        <div class="bg-[#FAEBD7] rounded-xl p-8">
          <h3 class="font-['Playfair_Display',Georgia,serif] text-2xl font-bold text-[#2C1810] mb-6">
            {t.hotel.location.address.title}
          </h3>
          <p class="font-['Open_Sans',Arial,sans-serif] text-[#5C4033] text-lg whitespace-pre-line">
            {t.hotel.location.address.text}
          </p>
        </div>
        <div>
          <img
            src="/images/vogthof-map.png"
            alt="Directions to Vogthof"
            class="w-full"
          />
        </div>
      </div>
      
      <div class="bg-[#FDF5E6] rounded-xl p-8">
        <h3 class="font-['Playfair_Display',Georgia,serif] text-2xl font-bold text-[#2C1810] mb-6">
          {t.hotel.location.gettingHere.title}
        </h3>
        <ul class="space-y-4">
          <li class="flex items-start">
            <span class="text-[#2D5A27] mr-3">✈️</span>
            <span class="font-['Open_Sans',Arial,sans-serif] text-[#5C4033]">{t.hotel.location.gettingHere.airport}</span>
          </li>
          <li class="flex items-start">
            <span class="text-[#2D5A27] mr-3">🚂</span>
            <span class="font-['Open_Sans',Arial,sans-serif] text-[#5C4033]">{t.hotel.location.gettingHere.train}</span>
          </li>
          <li class="flex items-start">
            <span class="text-[#2D5A27] mr-3">🅿️</span>
            <span class="font-['Open_Sans',Arial,sans-serif] text-[#5C4033]">{t.hotel.location.gettingHere.parking}</span>
          </li>
        </ul>
      </div>
    </div>
  </Section>

  <ContactSection
    id="contact"
    title={t.hotel.contact.title}
    phoneLabel={t.hotel.contact.phone}
    hoursLabel={t.hotel.contact.openingHours}
    openingHours={[
      'Mon-Thu: 11:30-14:00 & 18:00-22:00',
      'Fri: Closed',
      'Sat: 18:00-22:00',
      'Sun: 11:30-14:00'
    ]}
    ctaText={t.hotel.contact.cta}
    ctaLink="/en/rooms"
    variant="cards"
    background="background"
  />
</Layout>
