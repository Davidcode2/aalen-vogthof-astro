---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import { getTranslations } from '../i18n/translations';

const locale = 'de';
const t = getTranslations(locale);

const contactInfo = {
  owner: 'Reiner Ilg',
  address: 'Bergbaustraße 28/1, 73433 Aalen-Röthardt',
  email: 'info@aalen-vogthof.de',
  phone: '+49(0)7361 73688',
  fax: '+49(0)7361 77882'
};

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'PrivacyPolicy',
  name: 'Vogthof Landgasthof - Datenschutzerklärung',
  owner: contactInfo.owner,
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Bergbaustraße 28/1',
    addressLocality: 'Aalen-Röthardt',
    postalCode: '73433',
    addressCountry: 'DE'
  },
  email: contactInfo.email,
  telephone: contactInfo.phone
};
---

<Layout 
  title="Datenschutz | Vogthof Landgasthof"
  description="Datenschutzerklärung des Vogthof Landgasthof. Information über die Verarbeitung personenbezogener Daten."
  locale={locale}
>
  <!-- Hero Section -->
  <Section background="surface" padding="medium">
    <div class="text-center">
      <h1 class="font-display break-words text-4xl md:text-5xl lg:text-6xl font-bold text-primary mb-4">
        {t.datenschutz.hero.title}
      </h1>
      <p class="font-body text-lg text-secondary max-w-2xl mx-auto">
        {t.datenschutz.hero.subtitle}
      </p>
    </div>
  </Section>

  <!-- Legal Content -->
  <Section background="background" padding="large">
    <div class="max-w-4xl mx-auto space-y-8">
      <!-- 1. Name und Kontaktdaten -->
      <div class="bg-white rounded-xl shadow-lg p-8">
        <h2 class="font-display break-words text-2xl font-bold text-primary mb-6">
          {t.datenschutz.sections.responsible.title}
        </h2>
        <p class="font-body text-secondary mb-4">
          {t.datenschutz.sections.responsible.text}
        </p>
        <div class="space-y-3 pl-4 border-l-4 border-accent">
          <p class="font-body text-lg text-primary font-semibold">
            {contactInfo.owner}
          </p>
          <p class="font-body text-secondary">
            {contactInfo.address}
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
            <div>
              <p class="font-body text-sm text-secondary">E-Mail:</p>
              <a href={`mailto:${contactInfo.email}`} class="font-body text-primary hover:text-secondary">
                {contactInfo.email}
              </a>
            </div>
            <div>
              <p class="font-body text-sm text-secondary">Telefon:</p>
              <a href={`tel:${contactInfo.phone.replace(/\D/g, '')}`} class="font-body text-primary hover:text-secondary">
                {contactInfo.phone}
              </a>
            </div>
            <div>
              <p class="font-body text-sm text-secondary">Telefax:</p>
              <p class="font-body text-primary">{contactInfo.fax}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- 2. Umfang und Zweck -->
      <div class="bg-white rounded-xl shadow-lg p-8">
        <h2 class="font-display break-words text-2xl font-bold text-primary mb-6">
          {t.datenschutz.sections.scope.title}
        </h2>
        <p class="font-body text-secondary leading-relaxed">
          {t.datenschutz.sections.scope.text}
        </p>
      </div>

      <!-- 3. Weitergabe von Daten -->
      <div class="bg-white rounded-xl shadow-lg p-8">
        <h2 class="font-display break-words text-2xl font-bold text-primary mb-6">
          {t.datenschutz.sections.sharing.title}
        </h2>
        <p class="font-body text-secondary leading-relaxed">
          {t.datenschutz.sections.sharing.text}
        </p>
      </div>

      <!-- 4. Cookies -->
      <div class="bg-white rounded-xl shadow-lg p-8">
        <h2 class="font-display break-words text-2xl font-bold text-primary mb-6">
          {t.datenschutz.sections.cookies.title}
        </h2>
        <p class="font-body text-secondary leading-relaxed">
          {t.datenschutz.sections.cookies.text}
        </p>
      </div>

      <!-- 5. Google Maps -->
      <div class="bg-white rounded-xl shadow-lg p-8">
        <h2 class="font-display break-words text-2xl font-bold text-primary mb-6">
          {t.datenschutz.sections.maps.title}
        </h2>
        <p class="font-body text-secondary leading-relaxed">
          {t.datenschutz.sections.maps.text}
        </p>
      </div>

      <!-- 6. Ihre Rechte -->
      <div class="bg-white rounded-xl shadow-lg p-8">
        <h2 class="font-display break-words text-2xl font-bold text-primary mb-6">
          {t.datenschutz.sections.rights.title}
        </h2>
        <p class="font-body text-secondary leading-relaxed">
          {t.datenschutz.sections.rights.text}
        </p>
      </div>

      <!-- 7. Stand -->
      <div class="bg-white rounded-xl shadow-lg p-8">
        <h2 class="font-display break-words text-2xl font-bold text-primary mb-6">
          {t.datenschutz.sections.update.title}
        </h2>
        <p class="font-body text-secondary leading-relaxed">
          {t.datenschutz.sections.update.text}
        </p>
      </div>

      <!-- Quick Links -->
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/contact"
          class="inline-flex items-center gap-2 px-6 py-3 bg-primary hover:bg-secondary text-white font-semibold rounded-lg shadow-lg hover:shadow-xl transition-all duration-300"
        >
          {t.common.nav.contact}
        </a>
        <a
          href="/impressum"
          class="inline-flex items-center gap-2 px-6 py-3 border-2 border-primary text-primary hover:bg-primary hover:text-white font-semibold rounded-lg transition-all duration-300"
        >
          {t.common.footer.imprint}
        </a>
      </div>
    </div>
  </Section>
</Layout>
