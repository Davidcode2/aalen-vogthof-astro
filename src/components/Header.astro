---
const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Hotel & Rooms', href: '/hotel' },
  { label: 'Restaurant', href: '/restaurant' },
  { label: 'Menus', href: '/menus' },
  { label: 'Events', href: '/events' },
  { label: 'Activities', href: '/activities' },
  { label: 'Contact', href: '/contact' },
];
---

<header class="sticky top-0 z-50 bg-[#2D5A27] shadow-lg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center">
        <span class="font-['Playfair_Display',Georgia,serif] text-2xl font-bold text-[#F5DEB3]">
          Vogthof
        </span>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex space-x-1">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="px-3 py-2 text-sm font-semibold text-[#F5DEB3] hover:text-white hover:bg-[#8B4513] rounded-md transition-colors duration-200"
          >
            {item.label}
          </a>
        ))}
      </nav>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-button"
        class="md:hidden p-2 rounded-md text-[#F5DEB3] hover:text-white hover:bg-[#8B4513] transition-colors"
        aria-label="Toggle menu"
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Navigation -->
  <div id="mobile-menu" class="hidden md:hidden bg-[#2D5A27] border-t border-[#8B4513]">
    <div class="px-2 pt-2 pb-3 space-y-1">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="block px-3 py-2 text-base font-medium text-[#F5DEB3] hover:text-white hover:bg-[#8B4513] rounded-md transition-colors duration-200"
        >
          {item.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');

  if (mobileMenuButton && mobileMenu) {
    mobileMenuButton.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });
  }
</script>
