---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import ContactSection from '../components/ContactSection.astro';
import { getTranslations } from '../i18n/translations';

const locale = 'de';
const t = getTranslations(locale);

const amenities = [
  { key: 'rooms', icon: '🛏️' },
  { key: 'quality', icon: '⭐' },
  { key: 'location', icon: '🌿' },
  { key: 'dining', icon: '☕' },
  { key: 'wifi', icon: '📶' },
  { key: 'parking', icon: '🚗' },
] as const;
---

<Layout 
  title="Hotel | Landgasthof Vogthof"
  description="Ihr ruhiger Rückzugsort auf dem Land. Erleben Sie traditionelle Gastfreundschaft mit modernem Komfort."
  locale={locale}
>
  <Hero
    headline={t.hotel.hero.headline}
    subheadline={t.hotel.hero.subheadline}
    backgroundImage="/images/Datenschutz-header.jpg"
    ctaText={t.hotel.hero.ctaPrimary}
    ctaLink="/rooms"
    ctaSecondaryText={t.hotel.hero.ctaSecondary}
    ctaSecondaryLink="#contact"
    height="large"
    overlayType="gradient"
  />

  <!-- Introduction Section -->
  <Section title={t.hotel.welcome.title} subtitle={t.hotel.welcome.subtitle} padding="xlarge">
    <div class="max-w-3xl mx-auto text-center">
      <div class="relative">
        {/* Decorative quote marks */}
        <span class="absolute -top-8 left-0 text-8xl text-secondary-200 font-display opacity-50">"</span>
        
        <p class="font-body text-lg lg:text-xl text-secondary leading-relaxed mb-8 relative z-10">
          {t.hotel.welcome.paragraph1}
        </p>
        <p class="font-body text-lg text-secondary leading-relaxed mb-10 relative z-10">
          {t.hotel.welcome.paragraph2}
        </p>
      </div>
      
      <a href="/rooms" class="btn-primary">
        {t.hotel.welcome.cta}
      </a>
    </div>
  </Section>

  <!-- Amenities Grid -->
  <Section title={t.hotel.amenities.title} background="cream" padding="xlarge">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {amenities.map((amenity) => (
        <div class="group bg-paper p-8 shadow-subtle hover:shadow-soft transition-all duration-500 hover:-translate-y-1">
          <div class="text-4xl mb-4 transform group-hover:scale-110 transition-transform duration-300">{amenity.icon}</div>
          <h3 class="font-display text-xl font-semibold text-dark mb-3">
            {t.hotel.amenities.items[amenity.key].title}
          </h3>
          <p class="text-secondary leading-relaxed">
            {t.hotel.amenities.items[amenity.key].description}
          </p>
        </div>
      ))}
    </div>
  </Section>

  <!-- Location Section -->
  <Section title={t.hotel.location.title} subtitle={t.hotel.location.subtitle} background="paper" padding="xlarge">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
      <div class="space-y-8">
        <div class="bg-cream p-8 border border-light shadow-subtle">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-full bg-secondary-100 flex items-center justify-center">
              <svg class="w-5 h-5 text-secondary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <h3 class="font-display text-xl font-semibold text-dark">
              {t.hotel.location.address.title}
            </h3>
          </div>
          <p class="font-body text-secondary text-lg leading-relaxed whitespace-pre-line">
            {t.hotel.location.address.text}
          </p>
        </div>
        
        <div class="relative group overflow-hidden shadow-medium">
          <img
            src="/images/vogthof-map.png"
            alt="Anfahrt zum Vogthof"
            class="w-full transition-transform duration-700 group-hover:scale-105"
          />
        </div>
      </div>
      
      <div class="bg-cream p-8 border border-light shadow-subtle">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-full bg-secondary-100 flex items-center justify-center">
            <svg class="w-5 h-5 text-secondary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
            </svg>
          </div>
          <h3 class="font-display text-xl font-semibold text-dark">
            {t.hotel.location.gettingHere.title}
          </h3>
        </div>
        
        <ul class="space-y-6">
          <li class="flex items-start gap-4 pb-6 border-b border-light">
            <span class="text-2xl flex-shrink-0">✈️</span>
            <div>
              <p class="font-semibold text-dark mb-1">Flughafen</p>
              <p class="font-body text-secondary">{t.hotel.location.gettingHere.airport}</p>
            </div>
          </li>
          <li class="flex items-start gap-4 pb-6 border-b border-light">
            <span class="text-2xl flex-shrink-0">🚂</span>
            <div>
              <p class="font-semibold text-dark mb-1">Bahnhof</p>
              <p class="font-body text-secondary">{t.hotel.location.gettingHere.train}</p>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <span class="text-2xl flex-shrink-0">🅿️</span>
            <div>
              <p class="font-semibold text-dark mb-1">Parken</p>
              <p class="font-body text-secondary">{t.hotel.location.gettingHere.parking}</p>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </Section>

  <ContactSection
    id="contact"
    title={t.hotel.contact.title}
    phoneLabel={t.hotel.contact.phone}
    hoursLabel={t.hotel.contact.openingHours}
    openingHours={[
      'Mo-Do: 11:30-14:00 & 18:00-22:00',
      'Fr: Ruhetag',
      'Sa: 18:00-22:00',
      'So: 11:30-14:00'
    ]}
    ctaText={t.hotel.contact.cta}
    ctaLink="/rooms"
    variant="cards"
    background="base"
  />
</Layout>
