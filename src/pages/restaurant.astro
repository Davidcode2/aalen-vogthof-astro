---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
import ContactSection from '../components/ContactSection.astro';
import { getTranslations } from '../i18n/translations';

const locale = 'de';
const t = getTranslations(locale);

const heroImage = '/images/restaurant_room_full_length.jpg';

const privateRooms = [
  { key: 'vogtstube', image: '/images/restaurant/vogtstube.jpg' },
  { key: 'braunenberg', image: '/images/restaurant/braunenbergstube.jpg' },
  { key: 'beerGarden', image: '/images/restaurant/beergarden.jpg' },
] as const;
---

<Layout 
  title="Restaurant | Landgasthof Vogthof"
  description="Traditionelle schwäbische Gastfreundschaft trifft auf elegante Küche."
  locale={locale}
>
  <!-- Hero Section -->
  <Hero
    headline={t.restaurant.hero.headline}
    subheadline={t.restaurant.hero.subheadline}
    backgroundImage={heroImage}
    ctaText={t.restaurant.hero.ctaPrimary}
    ctaLink="/menus"
    ctaSecondaryText={t.restaurant.hero.ctaSecondary}
    ctaSecondaryLink="#contact"
    height="large"
    overlayType="gradient"
  />

  <!-- Introduction Section -->
  <Section
    title={t.restaurant.heritage.title}
    subtitle={t.restaurant.heritage.subtitle}
    padding="xlarge"
  >
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div>
        <div class="flex items-center gap-4 mb-6">
          <span class="w-12 h-[1px] bg-secondary-400"></span>
          <span class="text-muted text-sm tracking-widest uppercase">Tradition</span>
        </div>
        
        <p class="font-body text-lg text-secondary leading-relaxed mb-6">
          {t.restaurant.heritage.paragraph1}
        </p>
        <p class="font-body text-lg text-secondary leading-relaxed mb-6">
          {t.restaurant.heritage.paragraph2}
        </p>
        <p class="font-body text-lg text-secondary leading-relaxed">
          {t.restaurant.heritage.paragraph3}
        </p>
      </div>
      
      <div class="relative group">
        <div class="absolute -inset-4 bg-secondary-200/30 rounded-sm transform -rotate-1 transition-transform duration-500 group-hover:-rotate-2"></div>
        <img
          src="/images/restaurant/braunenbergstube.jpg"
          alt="Restaurant interior"
          class="relative shadow-medium w-full rounded-sm"
        />
      </div>
    </div>
  </Section>

  <!-- Kitchen Philosophy Section -->
  <Section
    title={t.restaurant.philosophy.title}
    subtitle={t.restaurant.philosophy.subtitle}
    background="cream"
    padding="xlarge"
  >
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class="order-2 lg:order-1 relative group">
        <div class="absolute -inset-4 bg-primary-200/30 rounded-sm transform rotate-1 transition-transform duration-500 group-hover:rotate-2"></div>
        <img
          src="/images/kitchen/cu.jpg"
          alt="Chef in the kitchen"
          class="relative shadow-medium w-full rounded-sm"
        />
      </div>
      
      <div class="order-1 lg:order-2">
        <div class="flex items-center gap-4 mb-6">
          <span class="w-12 h-[1px] bg-secondary-400"></span>
          <span class="text-muted text-sm tracking-widest uppercase">Küche</span>
        </div>
        
        <p class="font-body text-lg text-secondary leading-relaxed mb-6">
          {t.restaurant.philosophy.paragraph1}
        </p>
        <p class="font-body text-lg text-secondary leading-relaxed mb-6">
          {t.restaurant.philosophy.paragraph2}
        </p>
        <p class="font-body text-lg text-secondary leading-relaxed">
          {t.restaurant.philosophy.paragraph3}
        </p>
      </div>
    </div>
  </Section>

  <!-- Chef Information -->
  <Section
    title={t.restaurant.chefs.title}
    subtitle={t.restaurant.chefs.subtitle}
    padding="xlarge"
  >
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      {/* Image */}
      <div class="relative overflow-hidden shadow-medium group">
        <img
          src="/images/chefs.jpg"
          alt="Reiner Ilg und Johannes Hänle"
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-primary-900/60 via-transparent to-transparent"></div>
        
        {/* Overlay text */}
        <div class="absolute bottom-6 left-6 right-6 text-white">
          <p class="font-display text-lg tracking-wider">Unsere Küchenchefs</p>
        </div>
      </div>

      {/* Chef Info Cards */}
      <div class="space-y-6">
        <!-- Reiner Ilg -->
        <div class="bg-paper p-8 shadow-subtle border-l-4 border-secondary-400 hover:shadow-soft transition-all duration-300">
          <div class="flex items-start gap-4">
            <div class="flex-1">
              <h3 class="font-display text-xl font-semibold text-dark mb-1">
                {t.restaurant.chefs.chef1.name}
              </h3>
              <p class="text-sm font-medium text-secondary-600 mb-4 tracking-wide uppercase">
                {t.restaurant.chefs.chef1.title}
              </p>
              <p class="text-secondary leading-relaxed">
                {t.restaurant.chefs.chef1.description}
              </p>
            </div>
          </div>
        </div>

        <!-- Johannes Hänle -->
        <div class="bg-paper p-8 shadow-subtle border-l-4 border-primary-600 hover:shadow-soft transition-all duration-300">
          <div class="flex items-start gap-4">
            <div class="flex-1">
              <h3 class="font-display text-xl font-semibold text-dark mb-1">
                {t.restaurant.chefs.chef2.name}
              </h3>
              <p class="text-sm font-medium text-secondary-600 mb-4 tracking-wide uppercase">
                {t.restaurant.chefs.chef2.title}
              </p>
              <p class="text-secondary leading-relaxed">
                {t.restaurant.chefs.chef2.description}
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- Private Rooms Section -->
  <Section
    title={t.restaurant.privateRooms.title}
    subtitle={t.restaurant.privateRooms.subtitle}
    background="cream"
    padding="xlarge"
  >
    <div class="grid md:grid-cols-3 gap-8">
      {privateRooms.map((room) => (
        <Card
          title={t.restaurant.privateRooms[room.key].name}
          description={t.restaurant.privateRooms[room.key].description}
          image={room.image}
          linkText={`Kapazität: ${t.restaurant.privateRooms[room.key].capacity}`}
          hoverEffect="lift"
        />
      ))}
    </div>

    <div class="text-center mt-16">
      <p class="text-secondary text-lg mb-6 max-w-xl mx-auto">
        {t.restaurant.privateRooms.contactText}
      </p>
      <a href="tel:07361-73688" class="btn-primary">
        {t.restaurant.privateRooms.cta}
      </a>
    </div>
  </Section>

  <!-- Beer Garden Highlight -->
  <Section
    title={t.restaurant.beerGarden.title}
    subtitle={t.restaurant.beerGarden.subtitle}
    padding="xlarge"
    id="beer-garden"
  >
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div>
        <div class="flex items-center gap-4 mb-6">
          <span class="w-12 h-[1px] bg-secondary-400"></span>
          <span class="text-muted text-sm tracking-widest uppercase">Im Freien</span>
        </div>
        
        <p class="font-body text-lg text-secondary leading-relaxed mb-6">
          {t.restaurant.beerGarden.paragraph1}
        </p>
        <p class="font-body text-lg text-secondary leading-relaxed mb-6">
          {t.restaurant.beerGarden.paragraph2}
        </p>
        <p class="font-body text-lg text-secondary leading-relaxed">
          {t.restaurant.beerGarden.paragraph3}
        </p>
      </div>
      
      <div class="relative group">
        <div class="absolute -inset-4 bg-secondary-200/30 rounded-sm transform rotate-1 transition-transform duration-500 group-hover:rotate-2"></div>
        <img
          src="/images/restaurant/beergarden.jpg"
          alt="Biergarten"
          class="relative shadow-medium w-full rounded-sm"
        />
      </div>
    </div>
  </Section>

  <ContactSection
    id="contact"
    title={t.restaurant.reserve.title}
    phoneLabel={t.restaurant.reserve.phone}
    hoursLabel={t.restaurant.reserve.hours}
    openingHours={[
      'Mo-Do: 11:30-14:00 & 18:00-22:00',
      'Fr: Ruhetag',
      'Sa: 18:00-22:00',
      'So: 11:30-14:00'
    ]}
    ctaText={t.restaurant.reserve.cta}
    ctaLink="/menus"
    variant="cards"
    background="paper"
  />
</Layout>
