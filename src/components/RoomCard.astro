---
interface Props {
  name: string;
  image: string;
  price: string;
  capacity: number;
  amenities?: string[];
  description?: string;
  detailsLink?: string;
  detailsText?: string;
}

const {
  name,
  image,
  price,
  capacity,
  amenities = [],
  description,
  detailsLink = '/contact',
  detailsText = 'Anfragen'
} = Astro.props;

const capacityLabels: Record<number, string> = {
  1: 'Einzelzimmer',
  2: 'Doppelzimmer',
  4: 'Familienzimmer',
};
---

<article class="group bg-paper overflow-hidden shadow-subtle hover:shadow-medium transition-all duration-500">
  <!-- Image Container -->
  <div class="relative overflow-hidden aspect-[16/10]">
    <img
      src={image}
      alt={name}
      class="w-full h-full object-cover transition-all duration-700 group-hover:scale-110"
    />
    
    {/* Gradient overlay */}
    <div class="absolute inset-0 bg-gradient-to-t from-primary-900/60 via-transparent to-transparent"></div>
    
    {/* Price Badge */}
    <div class="absolute bottom-4 right-4 bg-white/95 backdrop-blur-sm px-4 py-2 shadow-lg">
      <span class="font-display text-lg font-semibold text-primary-700">{price}</span>
      <span class="text-xs text-muted block">pro Nacht</span>
    </div>
    
    {/* Capacity Badge */}
    <div class="absolute top-4 left-4 bg-primary-900/90 backdrop-blur-sm text-white px-3 py-1.5 text-xs font-medium tracking-wider uppercase">
      {capacity} {capacity > 1 ? 'Personen' : 'Person'}
    </div>
  </div>

  <!-- Content -->
  <div class="p-6 lg:p-8">
    {/* Decorative line */}
    <div class="w-8 h-[2px] bg-secondary-400 mb-4 transition-all duration-300 group-hover:w-12"></div>
    
    <h3 class="font-display text-xl lg:text-2xl font-semibold text-dark mb-2">
      {name}
    </h3>
    
    <p class="text-sm text-muted mb-4 tracking-wide uppercase">{capacityLabels[capacity] || 'Zimmer'}</p>

    {description && (
      <p class="font-body text-secondary leading-relaxed mb-6 line-clamp-2">
        {description}
      </p>
    )}

    <!-- Amenities -->
    {amenities.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-6">
        {amenities.slice(0, 3).map((amenity) => (
          <span class="inline-block px-3 py-1 bg-surface text-secondary text-xs border border-light">
            {amenity}
          </span>
        ))}
        {amenities.length > 3 && (
          <span class="inline-block px-3 py-1 bg-surface text-muted text-xs border border-light">
            +{amenities.length - 3}
          </span>
        )}
      </div>
    )}

    <!-- CTA Button -->
    <a
      href={detailsLink}
      class="block w-full text-center py-3.5 bg-primary-700 hover:bg-primary-800 text-white font-medium tracking-wider uppercase text-sm transition-all duration-300"
    >
      {detailsText}
    </a>
  </div>
</article>
