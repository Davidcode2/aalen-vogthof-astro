---
import Layout from '../../layouts/Layout.astro';
import Section from '../../components/Section.astro';
import ContactForm from '../../components/ContactForm.astro';
import { getTranslations } from '../../i18n/translations';

const locale = 'en';
const t = getTranslations(locale);

const contactInfo = {
  phone: '07361-73688',
  fax: '07361-77882',
  email: 'info@aalen-vogthof.de',
  address: 'Bergbaustraße 28/1, 73433 Aalen-Röthardt',
};

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Restaurant',
  name: 'Vogthof Landgasthof',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Bergbaustraße 28/1',
    addressLocality: 'Aalen-Röthardt',
    postalCode: '73433',
    addressCountry: 'DE'
  },
  telephone: '+49-7361-73688',
  openingHours: [
    'Mo-Th 11:30-14:00',
    'Mo-We 18:00-21:30',
    'Sa 18:00-22:00',
    'Su 11:30-14:00'
  ]
};
---

<Layout 
  title="Contact | Vogthof Landgasthof"
  description="Contact Vogthof Landgasthof. Phone, email, opening hours and address in Aalen-Röthardt."
  locale={locale}
>
  <!-- Hero Section -->
  <Section background="antique" padding="medium">
    <div class="text-center">
      <h1 class="font-['Playfair_Display',Georgia,serif] text-4xl md:text-5xl lg:text-6xl font-bold text-[#2C1810] mb-4">
        {t.contact.hero.title}
      </h1>
      <p class="font-['Open_Sans',Arial,sans-serif] text-lg text-[#5C4033] max-w-2xl mx-auto">
        {t.contact.hero.subtitle}
      </p>
    </div>
  </Section>

  <!-- Contact Information & Form Section -->
  <Section background="cream" padding="large">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      <!-- Contact Info -->
      <div class="space-y-8">
        <div class="bg-white rounded-xl shadow-lg p-8">
          <h2 class="font-['Playfair_Display',Georgia,serif] text-2xl font-bold text-[#2C1810] mb-6">
            {t.contact.info.title}
          </h2>
          
          <div class="space-y-4">
            <!-- Phone -->
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-[#8B4513] rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                </svg>
              </div>
              <div>
                <p class="font-['Open_Sans',Arial,sans-serif] text-sm text-[#5C4033] mb-1">{t.contact.info.phone}</p>
                <a href={`tel:${contactInfo.phone}`} class="font-['Open_Sans',Arial,sans-serif] text-lg text-[#8B4513] hover:text-[#2D5A27] font-semibold transition-colors">
                  {contactInfo.phone}
                </a>
              </div>
            </div>

            <!-- Fax -->
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-[#8B4513] rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                </svg>
              </div>
              <div>
                <p class="font-['Open_Sans',Arial,sans-serif] text-sm text-[#5C4033] mb-1">{t.contact.info.fax}</p>
                <p class="font-['Open_Sans',Arial,sans-serif] text-lg text-[#2C1810]">
                  {contactInfo.fax}
                </p>
              </div>
            </div>

            <!-- Email -->
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-[#8B4513] rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
              </div>
              <div>
                <p class="font-['Open_Sans',Arial,sans-serif] text-sm text-[#5C4033] mb-1">{t.contact.info.email}</p>
                <a href={`mailto:${contactInfo.email}`} class="font-['Open_Sans',Arial,sans-serif] text-lg text-[#8B4513] hover:text-[#2D5A27] font-semibold transition-colors">
                  {contactInfo.email}
                </a>
              </div>
            </div>

            <!-- Address -->
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-[#8B4513] rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
              </div>
              <div>
                <p class="font-['Open_Sans',Arial,sans-serif] text-sm text-[#5C4033] mb-1">{t.contact.info.address}</p>
                <p class="font-['Open_Sans',Arial,sans-serif] text-lg text-[#2C1810]">
                  {contactInfo.address}
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Opening Hours -->
        <div class="bg-white rounded-xl shadow-lg p-8">
          <h2 class="font-['Playfair_Display',Georgia,serif] text-2xl font-bold text-[#2C1810] mb-6">
            {t.contact.hours.title}
          </h2>
          <div class="space-y-3">
            {t.contact.hours.schedule.map((schedule) => (
              <div class="flex justify-between items-center py-2 border-b border-[#D4A574] last:border-0">
                <span class="font-['Open_Sans',Arial,sans-serif] text-[#2C1810]">{schedule.days}</span>
                <span class="font-['Open_Sans',Arial,sans-serif] font-semibold text-[#8B4513]">{schedule.hours}</span>
              </div>
            ))}
          </div>
          <p class="font-['Open_Sans',Arial,sans-serif] text-sm text-[#5C4033] mt-4 italic">
            {t.contact.hours.note}
          </p>
        </div>
      </div>

      <!-- Contact Form -->
      <div>
        <h2 class="font-['Playfair_Display',Georgia,serif] text-2xl font-bold text-[#2C1810] mb-6">
          {t.contact.form.title}
        </h2>
        <ContactForm />
      </div>
    </div>
  </Section>

  <!-- Map Section -->
  <Section background="old-lace" padding="large">
    <div class="text-center mb-8">
      <h2 class="font-['Playfair_Display',Georgia,serif] text-3xl font-bold text-[#2C1810] mb-4">
        {t.contact.map.title}
      </h2>
      <p class="font-['Open_Sans',Arial,sans-serif] text-lg text-[#5C4033]">
        {t.contact.map.address}
      </p>
    </div>
    <div class="bg-white rounded-xl shadow-lg p-4 overflow-hidden">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2603.6!2d10.0!3d48.8!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4799a3f0f0000001%3A0x0000000000000000!2sAalen-R%C3%B6thardt!5e0!3m2!1sde!2sde!4v1600000000000!5m2!1sde!2sde"
        width="100%"
        height="450"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        class="rounded-lg"
        title="Vogthof Landgasthof Location"
      ></iframe>
    </div>
    <div class="mt-6 flex flex-wrap justify-center gap-4">
      <a
        href="https://www.google.com/maps/dir/?api=1&destination=Bergbaustraße+28/1,+73433+Aalen-Röthardt"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 bg-[#8B4513] hover:bg-[#2D5A27] text-white font-semibold rounded-lg shadow-lg hover:shadow-xl transition-all duration-300"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path>
        </svg>
        {t.contact.map.ctaRoute}
      </a>
      <a
        href={`tel:${contactInfo.phone}`}
        class="inline-flex items-center gap-2 px-6 py-3 bg-[#5C4033] hover:bg-[#8B4513] text-white font-semibold rounded-lg shadow-lg hover:shadow-xl transition-all duration-300"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
        </svg>
        {t.contact.map.ctaCall}
      </a>
    </div>
  </Section>

  <!-- Additional Info Section -->
  <Section background="white" padding="large">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-['Playfair_Display',Georgia,serif] text-3xl font-bold text-[#2C1810] mb-6">
        {t.contact.events.title}
      </h2>
      <p class="font-['Open_Sans',Arial,sans-serif] text-lg text-[#5C4033] mb-6 leading-relaxed">
        {t.contact.events.text}
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/en/menus"
          class="inline-flex items-center gap-2 px-6 py-3 border-2 border-[#8B4513] text-[#8B4513] hover:bg-[#8B4513] hover:text-white font-semibold rounded-lg transition-all duration-300"
        >
          {t.contact.events.ctaMenu}
        </a>
        <a
          href="/en/tagesessen"
          class="inline-flex items-center gap-2 px-6 py-3 border-2 border-[#8B4513] text-[#8B4513] hover:bg-[#8B4513] hover:text-white font-semibold rounded-lg transition-all duration-300"
        >
          {t.contact.events.ctaDaily}
        </a>
      </div>
    </div>
  </Section>
</Layout>
