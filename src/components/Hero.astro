---
interface Props {
  backgroundImage?: string;
  headline?: string;
  showLogo?: boolean;
  subheadline?: string;
  ctaText?: string;
  ctaLink?: string;
  ctaSecondaryText?: string;
  ctaSecondaryLink?: string;
  height?: 'full' | 'large' | 'medium';
  overlayType?: 'default' | 'radial' | 'dark';
}

const {
  backgroundImage = '/images/hero-default.jpg',
  headline,
  showLogo = false,
  subheadline,
  ctaText,
  ctaLink,
  ctaSecondaryText,
  ctaSecondaryLink,
  height = 'large',
  overlayType = 'default'
} = Astro.props;

const heightClasses = {
  full: 'min-h-screen',
  large: 'min-h-[70vh]',
  medium: 'min-h-[50vh]'
};
---

<section class={`relative ${heightClasses[height]} flex items-center justify-center overflow-hidden`}>
  <!-- Background Image -->
  <div class="absolute inset-0 z-0">
    {backgroundImage ? (
      <img
        src={backgroundImage}
        alt=""
        class="w-full h-full object-cover"
      />
    ) : (
      <div class="w-full h-full bg-gradient-to-br from-secondary to-primary"></div>
    )}
  </div>

  <!-- Dark Overlay -->
  {overlayType === 'radial' ? (
    <div class="absolute inset-0 z-10 bg-[radial-gradient(circle_at_center,transparent_0%,rgba(0,0,0,0.3)_50%,rgba(0,0,0,0.6)_100%)]"></div>
  ) : overlayType === 'dark' ? (
    <div class="absolute inset-0 z-10 bg-gradient-to-b from-black/60 via-black/50 to-black/70"></div>
  ) : (
    <div class="absolute inset-0 z-10 bg-gradient-to-b from-black/50 via-black/40 to-black/60"></div>
  )}

  <!-- Content -->
  <div class="relative z-20 container mx-auto px-4 text-center text-white">
    {showLogo ? (
      <div class="mb-6">
        <img
          src="/images/logo.png"
          alt="Landgasthof Vogthof"
          class="w-48 md:w-64 lg:w-80 mx-auto drop-shadow-2xl"
        />
      </div>
    ) : headline ? (
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold mb-4 leading-tight">
        {headline}
      </h1>
    ) : null}

    {subheadline && (
      <p class="font-body text-lg md:text-xl mb-8 max-w-2xl mx-auto opacity-90">
        {subheadline}
      </p>
    )}

    <div class="flex flex-wrap justify-center gap-4">
      {ctaText && ctaLink && (
        <a
          href={ctaLink}
          class="inline-block px-6 py-3 md:px-8 md:py-3 bg-primary hover:bg-primary-light text-white font-semibold rounded-md transition-all duration-300 shadow-lg hover:shadow-xl"
        >
          {ctaText}
        </a>
      )}

      {ctaSecondaryText && ctaSecondaryLink && (
        <a
          href={ctaSecondaryLink}
          class="inline-block px-6 py-3 md:px-8 md:py-3 border-2 border-white hover:bg-white hover:text-secondary text-white font-semibold rounded-md transition-all duration-300"
        >
          {ctaSecondaryText}
        </a>
      )}
    </div>
  </div>

  <!-- Decorative Element -->
  <div class="absolute bottom-0 left-0 right-0 z-20">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto">
      <path d="M0 60V45C240 30 480 15 720 15C960 15 1200 30 1440 45V60H0Z" fill="#FDFBF7"/>
    </svg>
  </div>
</section>
