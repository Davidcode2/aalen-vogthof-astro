---
const currentYear = new Date().getFullYear();

const quickLinks = [
  { label: 'Hotel', href: '/hotel' },
  { label: 'Rooms', href: '/rooms' },
  { label: 'Restaurant', href: '/restaurant' },
  { label: 'Menus', href: '/menus' },
  { label: 'Events', href: '/events' },
  { label: 'Contact', href: '/contact' },
];

const legalLinks = [
  { label: 'Impressum', href: '/impressum' },
  { label: 'Datenschutz', href: '/datenschutz' },
];
---

<footer class="bg-primary-900 text-secondary-200 relative overflow-hidden">
  {/* Decorative top border */}
  <div class="absolute top-0 left-0 right-0 h-[1px] bg-gradient-to-r from-transparent via-secondary-400/50 to-transparent"></div>
  
  {/* Background pattern */}
  <div class="absolute inset-0 opacity-5">
    <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23d4a574\' fill-opacity=\'0.4\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-8 py-16 lg:py-20">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">
      {/* Brand Column */}
      <div class="lg:col-span-1">
        <a href="/" class="inline-block mb-6">
          <img 
            src="/images/logo.png" 
            alt="Vogthof Landgasthof" 
            class="h-16 w-auto opacity-90"
          />
        </a>
        <p class="font-body text-secondary-300/80 text-sm leading-relaxed mb-6 max-w-xs">
          Family-run hospitality since 1983. Experience traditional Swabian warmth in the heart of Aalen.
        </p>
        {/* Social / Contact icons placeholder */}
        <div class="flex gap-4">
          <a href="tel:07361-73688" class="w-10 h-10 rounded-full border border-secondary-400/30 flex items-center justify-center text-secondary-300 hover:text-white hover:border-secondary-400 transition-all duration-300">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
          </a>
          <a href="mailto:info@aalen-vogthof.de" class="w-10 h-10 rounded-full border border-secondary-400/30 flex items-center justify-center text-secondary-300 hover:text-white hover:border-secondary-400 transition-all duration-300">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </a>
        </div>
      </div>

      {/* Contact Info */}
      <div>
        <h3 class="font-display text-lg font-medium text-white mb-6 tracking-wide">
          Contact
        </h3>
        <div class="space-y-4 text-sm">
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-secondary-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <div>
              <p class="font-medium text-secondary-200">Landgasthof Vogthof</p>
              <p class="text-secondary-400">Reiner & Bernadette Ilg</p>
              <p class="text-secondary-400">Bergbaustraße 28/1</p>
              <p class="text-secondary-400">73433 Aalen-Röthardt</p>
            </div>
          </div>
          
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-secondary-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <a href="tel:07361-73688" class="text-secondary-300 hover:text-white transition-colors">
              07361-73688
            </a>
          </div>
          
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-secondary-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <a href="mailto:info@aalen-vogthof.de" class="text-secondary-300 hover:text-white transition-colors">
              info@aalen-vogthof.de
            </a>
          </div>
        </div>
      </div>

      {/* Quick Links */}
      <div>
        <h3 class="font-display text-lg font-medium text-white mb-6 tracking-wide">
          Navigation
        </h3>
        <ul class="space-y-3 text-sm">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="text-secondary-300 hover:text-white transition-colors inline-flex items-center gap-2 group">
                <span class="w-1.5 h-1.5 rounded-full bg-secondary-500/50 group-hover:bg-secondary-400 transition-colors"></span>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Opening Hours */}
      <div>
        <h3 class="font-display text-lg font-medium text-white mb-6 tracking-wide">
          Opening Hours
        </h3>
        <div class="space-y-3 text-sm">
          <div class="flex justify-between items-center pb-3 border-b border-secondary-400/20">
            <span class="text-secondary-300">Mon – Thu</span>
            <span class="text-secondary-200">11:30 – 14:00<br/>18:00 – 22:00</span>
          </div>
          <div class="flex justify-between items-center pb-3 border-b border-secondary-400/20">
            <span class="text-secondary-300">Friday</span>
            <span class="text-secondary-500 italic">Closed</span>
          </div>
          <div class="flex justify-between items-center pb-3 border-b border-secondary-400/20">
            <span class="text-secondary-300">Saturday</span>
            <span class="text-secondary-200">18:00 – 22:00</span>
          </div>
          <div class="flex justify-between items-center">
            <span class="text-secondary-300">Sunday</span>
            <span class="text-secondary-200">11:30 – 14:00</span>
          </div>
        </div>
      </div>
    </div>

    {/* Bottom Bar */}
    <div class="mt-16 pt-8 border-t border-secondary-400/20">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-secondary-400">
        <p>&copy; {currentYear} Landgasthof Vogthof. All rights reserved.</p>
        <div class="flex gap-6">
          {legalLinks.map((link) => (
            <a href={link.href} class="hover:text-secondary-200 transition-colors">
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</footer>
