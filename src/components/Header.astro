---
import type { Locale } from '../i18n/types';
import { getTranslations, getCurrentLocale } from '../i18n/translations';

interface Props {
  locale?: Locale;
}

const { locale = 'de' } = Astro.props;
const t = getTranslations(locale);

// Get current path for language switcher
const currentPath = Astro.url.pathname;
const currentLocale = getCurrentLocale(currentPath);
const isGerman = currentLocale === 'de';

// Calculate alternate path
const alternatePath = isGerman 
  ? '/en' + currentPath 
  : currentPath.replace(/^\/en/, '') || '/';

const alternateLocale = isGerman ? 'en' : 'de';
const alternateLabel = isGerman ? 'English' : 'Deutsch';

// Navigation items using translations
const navItems = [
  { label: t.common.nav.hotel, href: locale === 'de' ? '/hotel' : '/en/hotel' },
  { label: t.common.nav.rooms, href: locale === 'de' ? '/rooms' : '/en/rooms' },
  { label: t.common.nav.restaurant, href: locale === 'de' ? '/restaurant' : '/en/restaurant' },
  { label: t.common.nav.menus, href: locale === 'de' ? '/menus' : '/en/menus' },
  { label: t.common.nav.events, href: locale === 'de' ? '/events' : '/en/events' },
  { label: t.common.nav.activities, href: locale === 'de' ? '/activities' : '/en/activities' },
  { label: t.common.nav.contact, href: locale === 'de' ? '/contact' : '/en/contact' },
];

// Home link based on locale
const homeHref = locale === 'de' ? '/' : '/en';
---

<header class="fixed top-0 left-0 right-0 z-50 transition-all duration-500" id="main-header">
  <div class="absolute inset-0 bg-primary-900/95 backdrop-blur-md border-b border-secondary-400/20 transition-all duration-500" id="header-bg"></div>
  
  <div class="relative max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex justify-between items-center h-20 lg:h-24">
      <!-- Logo (links to home) -->
      <a href={homeHref} class="flex items-center group relative z-10">
        <div class="relative overflow-hidden">
          <img 
            src="/images/logo.png" 
            alt="Vogthof Landgasthof" 
            class="h-14 lg:h-16 w-auto object-contain transition-transform duration-500 group-hover:scale-105"
          />
        </div>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-1">
        {navItems.map((item, index) => (
          <a
            href={item.href}
            class="relative px-4 py-2 text-sm tracking-wider uppercase font-medium text-secondary-200 hover:text-white transition-colors duration-300 group"
            style={`animation-delay: ${index * 50}ms`}
          >
            <span class="relative z-10">{item.label}</span>
            <span class="absolute bottom-0 left-1/2 -translate-x-1/2 w-0 h-[1px] bg-secondary-400 transition-all duration-300 group-hover:w-4/5"></span>
          </a>
        ))}
        
        <!-- Language Toggle -->
        <div class="ml-6 pl-6 border-l border-secondary-400/30">
          <a 
            href={alternatePath}
            class="flex items-center gap-2 text-sm tracking-wider text-secondary-300 hover:text-white transition-colors duration-300"
            aria-label={alternateLabel}
            title={alternateLabel}
          >
            <span class={`transition-all duration-300 ${isGerman ? 'text-secondary-400 font-medium' : 'text-secondary-500'}`}>DE</span>
            <span class="text-secondary-500 text-xs">/</span>
            <span class={`transition-all duration-300 ${!isGerman ? 'text-secondary-400 font-medium' : 'text-secondary-500'}`}>EN</span>
          </a>
        </div>
      </nav>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-button"
        class="lg:hidden relative z-10 p-2 text-secondary-200 hover:text-white transition-colors"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <div class="w-6 h-5 relative flex flex-col justify-between">
          <span class="w-full h-[2px] bg-current transition-all duration-300 origin-left" id="menu-line-1"></span>
          <span class="w-full h-[2px] bg-current transition-all duration-300" id="menu-line-2"></span>
          <span class="w-full h-[2px] bg-current transition-all duration-300 origin-left" id="menu-line-3"></span>
        </div>
      </button>
    </div>
  </div>

  <!-- Mobile Navigation -->
  <div id="mobile-menu" class="lg:hidden fixed inset-0 top-20 bg-primary-900/98 backdrop-blur-lg opacity-0 invisible transition-all duration-500">
    <div class="flex flex-col items-center justify-center h-full gap-6 px-6">
      {navItems.map((item, index) => (
        <a
          href={item.href}
          class="text-2xl tracking-widest uppercase font-medium text-secondary-200 hover:text-white transition-all duration-300 mobile-nav-link"
          style={`transform: translateY(20px); opacity: 0; transition-delay: ${index * 50}ms`}
        >
          {item.label}
        </a>
      ))}
      
      <!-- Mobile Language Toggle -->
      <div class="mt-8 pt-8 border-t border-secondary-400/30 w-full max-w-xs">
        <a 
          href={alternatePath}
          class="flex items-center justify-center gap-4 text-lg tracking-wider text-secondary-300 hover:text-white transition-colors"
        >
          <span class={isGerman ? 'text-secondary-400 font-medium' : 'text-secondary-500'}>Deutsch</span>
          <span class="text-secondary-500">|</span>
          <span class={!isGerman ? 'text-secondary-400 font-medium' : 'text-secondary-500'}>English</span>
        </a>
      </div>
    </div>
  </div>
</header>

<!-- Spacer for fixed header -->
<div class="h-20 lg:h-24"></div>

<script>
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuLine1 = document.getElementById('menu-line-1');
  const menuLine2 = document.getElementById('menu-line-2');
  const menuLine3 = document.getElementById('menu-line-3');
  const mobileNavLinks = document.querySelectorAll('.mobile-nav-link');
  const header = document.getElementById('main-header');
  const headerBg = document.getElementById('header-bg');

  let isMenuOpen = false;
  let lastScroll = 0;

  // Mobile menu toggle
  if (mobileMenuButton && mobileMenu) {
    mobileMenuButton.addEventListener('click', () => {
      isMenuOpen = !isMenuOpen;
      
      // Animate hamburger
      if (menuLine1 && menuLine2 && menuLine3) {
        if (isMenuOpen) {
          menuLine1.style.transform = 'rotate(45deg) translateY(-2px)';
          menuLine2.style.opacity = '0';
          menuLine3.style.transform = 'rotate(-45deg) translateY(2px)';
        } else {
          menuLine1.style.transform = 'none';
          menuLine2.style.opacity = '1';
          menuLine3.style.transform = 'none';
        }
      }
      
      // Toggle menu
      if (isMenuOpen) {
        mobileMenu.classList.remove('opacity-0', 'invisible');
        mobileMenu.classList.add('opacity-100', 'visible');
        mobileMenuButton.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
        
        // Animate links
        mobileNavLinks.forEach((link, index) => {
          setTimeout(() => {
            (link as HTMLElement).style.transform = 'translateY(0)';
            (link as HTMLElement).style.opacity = '1';
          }, 100 + index * 50);
        });
      } else {
        mobileMenu.classList.add('opacity-0', 'invisible');
        mobileMenu.classList.remove('opacity-100', 'visible');
        mobileMenuButton.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
        
        mobileNavLinks.forEach((link) => {
          (link as HTMLElement).style.transform = 'translateY(20px)';
          (link as HTMLElement).style.opacity = '0';
        });
      }
    });

    // Close menu on link click
    mobileNavLinks.forEach((link) => {
      link.addEventListener('click', () => {
        if (isMenuOpen) {
          mobileMenuButton.click();
        }
      });
    });
  }

  // Header scroll behavior
  if (header && headerBg) {
    window.addEventListener('scroll', () => {
      const currentScroll = window.pageYOffset;
      
      if (currentScroll > 50) {
        header.classList.add('shadow-lg');
        headerBg.classList.add('bg-primary-900/98');
        headerBg.classList.remove('bg-primary-900/95');
      } else {
        header.classList.remove('shadow-lg');
        headerBg.classList.remove('bg-primary-900/98');
        headerBg.classList.add('bg-primary-900/95');
      }
      
      lastScroll = currentScroll;
    });
  }
</script>
