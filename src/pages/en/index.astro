---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Section from '../../components/Section.astro';
import Card from '../../components/Card.astro';
import { getTranslations } from '../../i18n/translations';

const locale = 'en';
const t = getTranslations(locale);
---

<Layout 
  title="Landgasthof Vogthof - Hotel & Restaurant in Aalen"
  description="Family-run hotel and restaurant in Aalen-Röthardt since 1983. Enjoy traditional Swabian hospitality, comfortable rooms, and excellent cuisine."
  locale={locale}
>
  <!-- Hero Section -->
  <Hero
    headline={t.home.hero.headline}
    subheadline={t.home.hero.subheadline}
    backgroundImage="/images/hotel1.jpg"
    ctaText={t.home.hero.ctaPrimary}
    ctaLink="/en/rooms"
    ctaSecondaryText={t.home.hero.ctaSecondary}
    ctaSecondaryLink="/en/menus"
    height="large"
  />

  <!-- Introduction Section -->
  <Section
    title={t.home.welcome.title}
    subtitle={t.home.welcome.subtitle}
    background="cream"
  >
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-lg text-[#5C4033] leading-relaxed mb-6">
        {t.home.welcome.paragraph1}
      </p>
      <p class="text-lg text-[#5C4033] leading-relaxed">
        {t.home.welcome.paragraph2}
      </p>
    </div>
  </Section>

  <!-- Featured Offerings -->
  <Section
    title={t.home.offerings.title}
    subtitle={t.home.offerings.subtitle}
    background="old-lace"
  >
    <div class="grid md:grid-cols-3 gap-8">
      <Card
        title={t.home.offerings.rooms.title}
        description={t.home.offerings.rooms.description}
        image="/images/rooms/z1.jpg"
        link="/en/rooms"
        linkText={t.home.offerings.rooms.linkText}
        hoverEffect="lift"
      />
      <Card
        title={t.home.offerings.cuisine.title}
        description={t.home.offerings.cuisine.description}
        image="/images/eat/k1.jpg"
        link="/en/restaurant"
        linkText={t.home.offerings.cuisine.linkText}
        hoverEffect="lift"
      />
      <Card
        title={t.home.offerings.events.title}
        description={t.home.offerings.events.description}
        image="/images/f1.jpg"
        link="/en/events"
        linkText={t.home.offerings.events.linkText}
        hoverEffect="lift"
      />
    </div>
  </Section>

  <!-- Restaurant Preview -->
  <Section
    title={t.home.culinary.title}
    subtitle={t.home.culinary.subtitle}
    background="antique"
  >
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div class="relative">
        <img
          src="/images/restaurant/r1.jpg"
          alt="Restaurant Vogthof"
          class="rounded-lg shadow-xl w-full"
        />
      </div>
      <div class="prose prose-lg text-[#5C4033]">
        <p class="mb-6">
          {t.home.culinary.paragraph1}
        </p>
        <p class="mb-6">
          {t.home.culinary.paragraph2}
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href="/en/menus"
            class="inline-block px-6 py-3 bg-[#8B4513] hover:bg-[#A0522D] text-white font-semibold rounded-lg transition-all duration-300"
          >
            {t.home.culinary.ctaPrimary}
          </a>
          <a
            href="/en/restaurant"
            class="inline-block px-6 py-3 border-2 border-[#8B4513] text-[#8B4513] hover:bg-[#8B4513] hover:text-white font-semibold rounded-lg transition-all duration-300"
          >
            {t.home.culinary.ctaSecondary}
          </a>
        </div>
      </div>
    </div>
  </Section>

  <!-- Activities Preview -->
  <Section
    title={t.home.activities.title}
    subtitle={t.home.activities.subtitle}
    background="cream"
  >
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      <div class="bg-white rounded-lg p-6 shadow-md text-center">
        <div class="text-4xl mb-4">🥾</div>
        <h3 class="font-['Playfair_Display',Georgia,serif] text-lg font-bold text-[#2C1810] mb-2">
          {t.home.activities.hiking.title}
        </h3>
        <p class="text-sm text-[#5C4033]">
          {t.home.activities.hiking.description}
        </p>
      </div>
      <div class="bg-white rounded-lg p-6 shadow-md text-center">
        <div class="text-4xl mb-4">🚴</div>
        <h3 class="font-['Playfair_Display',Georgia,serif] text-lg font-bold text-[#2C1810] mb-2">
          {t.home.activities.cycling.title}
        </h3>
        <p class="text-sm text-[#5C4033]">
          {t.home.activities.cycling.description}
        </p>
      </div>
      <div class="bg-white rounded-lg p-6 shadow-md text-center">
        <div class="text-4xl mb-4">♨️</div>
        <h3 class="font-['Playfair_Display',Georgia,serif] text-lg font-bold text-[#2C1810] mb-2">
          {t.home.activities.wellness.title}
        </h3>
        <p class="text-sm text-[#5C4033]">
          {t.home.activities.wellness.description}
        </p>
      </div>
      <div class="bg-white rounded-lg p-6 shadow-md text-center">
        <div class="text-4xl mb-4">🏛️</div>
        <h3 class="font-['Playfair_Display',Georgia,serif] text-lg font-bold text-[#2C1810] mb-2">
          {t.home.activities.culture.title}
        </h3>
        <p class="text-sm text-[#5C4033]">
          {t.home.activities.culture.description}
        </p>
      </div>
    </div>
    <div class="text-center mt-8">
      <a
        href="/en/activities"
        class="inline-block px-8 py-4 bg-[#2D5A27] hover:bg-[#3D7A37] text-white font-semibold rounded-lg transition-all duration-300"
      >
        {t.home.activities.cta}
      </a>
    </div>
  </Section>

  <!-- Contact CTA -->
  <Section
    title={t.home.visit.title}
    subtitle={t.home.visit.subtitle}
    background="old-lace"
  >
    <div class="max-w-4xl mx-auto">
      <div class="grid md:grid-cols-3 gap-8 mb-8">
        <div class="bg-white p-6 rounded-lg shadow-md text-center">
          <h3 class="font-bold text-[#2C1810] mb-2">📍 {t.home.visit.address}</h3>
          <p class="text-[#5C4033] text-sm">
            Bergbaustraße 28/1<br />
            73433 Aalen-Röthardt
          </p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-md text-center">
          <h3 class="font-bold text-[#2C1810] mb-2">📞 {t.home.visit.phone}</h3>
          <p class="text-[#5C4033] text-sm">
            <a href="tel:07361-73688" class="hover:text-[#8B4513]">
              07361-73688
            </a>
          </p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-md text-center">
          <h3 class="font-bold text-[#2C1810] mb-2">✉️ {t.home.visit.email}</h3>
          <p class="text-[#5C4033] text-sm">
            <a href="mailto:info@aalen-vogthof.de" class="hover:text-[#8B4513]">
              info@aalen-vogthof.de
            </a>
          </p>
        </div>
      </div>
      <div class="text-center">
        <a
          href="/en/contact"
          class="inline-block px-8 py-4 bg-[#8B4513] hover:bg-[#A0522D] text-white font-semibold rounded-lg transition-all duration-300 shadow-lg hover:shadow-xl"
        >
          {t.home.visit.cta}
        </a>
      </div>
    </div>
  </Section>
</Layout>
