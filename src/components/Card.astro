---
interface Props {
  title: string;
  description?: string;
  image?: string;
  link?: string;
  linkText?: string;
  hoverEffect?: 'lift' | 'zoom' | 'shadow' | 'none';
}

const {
  title,
  description,
  image,
  link,
  linkText = 'Learn More',
  hoverEffect = 'lift'
} = Astro.props;

const hoverClasses = {
  lift: 'group-hover:-translate-y-2',
  zoom: 'group-hover:scale-[1.02]',
  shadow: 'group-hover:shadow-medium',
  none: ''
};

const ContentWrapper = link ? 'a' : 'div';
const wrapperProps = link ? { href: link, class: `block group bg-paper overflow-hidden shadow-subtle hover:shadow-medium transition-all duration-500 ${hoverClasses[hoverEffect]}` } : { class: `bg-paper overflow-hidden shadow-subtle transition-all duration-300 ${hoverClasses[hoverEffect]}` };
---

<ContentWrapper {...wrapperProps}>
  <!-- Image -->
  {image && (
    <div class="relative overflow-hidden aspect-[4/3]">
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover transition-all duration-700 group-hover:scale-110"
      />
      <!-- Subtle gradient overlay on hover -->
      <div class="absolute inset-0 bg-gradient-to-t from-primary-900/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
    </div>
  )}

  <!-- Content -->
  <div class="p-6 lg:p-8">
    {/* Decorative line */}
    <div class="w-8 h-[2px] bg-secondary-400 mb-4 transition-all duration-300 group-hover:w-12"></div>
    
    <h3 class="font-display text-xl lg:text-2xl font-semibold text-dark mb-3 group-hover:text-primary-600 transition-colors duration-300">
      {title}
    </h3>

    {description && (
      <p class="font-body text-secondary leading-relaxed mb-6">
        {description}
      </p>
    )}

    {link && (
      <span class="inline-flex items-center text-primary-600 font-medium group/link">
        <span class="link-animated text-sm tracking-wider uppercase">{linkText}</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 ml-2 transition-transform duration-300 group-hover/link:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </span>
    )}
  </div>
</ContentWrapper>
