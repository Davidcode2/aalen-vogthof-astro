---
import type { Locale } from '../i18n/types';
import { getTranslations, getAlternatePath, getCurrentLocale } from '../i18n/translations';

interface Props {
  locale?: Locale;
}

const { locale = 'de' } = Astro.props;
const t = getTranslations(locale);

// Get current path for language switcher
const currentPath = Astro.url.pathname;
const currentLocale = getCurrentLocale(currentPath);
const isGerman = currentLocale === 'de';

// Calculate alternate path
const alternatePath = isGerman 
  ? '/en' + currentPath 
  : currentPath.replace(/^\/en/, '') || '/';

const alternateLocale = isGerman ? 'en' : 'de';
const alternateLabel = isGerman ? 'Switch to English' : 'Zu Deutsch wechseln';

// Navigation items using translations
const navItems = [
  { label: t.common.nav.hotel, href: locale === 'de' ? '/hotel' : '/en/hotel' },
  { label: t.common.nav.rooms, href: locale === 'de' ? '/rooms' : '/en/rooms' },
  { label: t.common.nav.restaurant, href: locale === 'de' ? '/restaurant' : '/en/restaurant' },
  { label: t.common.nav.menus, href: locale === 'de' ? '/menus' : '/en/menus' },
  { label: t.common.nav.events, href: locale === 'de' ? '/events' : '/en/events' },
  { label: t.common.nav.activities, href: locale === 'de' ? '/activities' : '/en/activities' },
  { label: t.common.nav.contact, href: locale === 'de' ? '/contact' : '/en/contact' },
];

// Home link based on locale
const homeHref = locale === 'de' ? '/' : '/en';
---

<header class="sticky top-0 z-50 bg-secondary shadow-lg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <!-- Logo (links to home) -->
      <a href={homeHref} class="flex items-center">
        <span class="font-display text-2xl font-bold text-gold-light">
          Vogthof
        </span>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden md:flex items-center space-x-1">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="px-3 py-2 text-sm font-semibold text-gold-light hover:text-white hover:bg-primary rounded-md transition-colors duration-200"
          >
            {item.label}
          </a>
        ))}
        
        <!-- Language Toggle -->
        <a 
          href={alternatePath}
          class="ml-4 flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-gold/30 hover:bg-primary transition-colors"
          aria-label={alternateLabel}
          title={alternateLabel}
        >
          <span class={isGerman ? 'text-gold-light font-bold' : 'text-gold-light/60'}>DE</span>
          <span class="text-gold-light/60">/</span>
          <span class={!isGerman ? 'text-gold-light font-bold' : 'text-gold-light/60'}>EN</span>
        </a>
      </nav>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-button"
        class="md:hidden p-2 rounded-md text-gold-light hover:text-white hover:bg-primary transition-colors"
        aria-label="Toggle menu"
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Navigation -->
  <div id="mobile-menu" class="hidden md:hidden bg-secondary border-t border-primary">
    <div class="px-2 pt-2 pb-3 space-y-1">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="block px-3 py-2 text-base font-medium text-gold-light hover:text-white hover:bg-primary rounded-md transition-colors duration-200"
        >
          {item.label}
        </a>
      ))}
      
      <!-- Mobile Language Toggle -->
      <div class="pt-4 mt-4 border-t border-primary">
        <a 
          href={alternatePath}
          class="flex items-center justify-between px-3 py-2 text-base font-medium text-gold-light hover:text-white hover:bg-primary rounded-md transition-colors"
        >
          <span>{alternateLabel}</span>
          <span class="flex items-center gap-2">
            <span class={isGerman ? 'text-gold-light font-bold' : 'text-gold-light/60'}>DE</span>
            <span class="text-gold-light/60">|</span>
            <span class={!isGerman ? 'text-gold-light font-bold' : 'text-gold-light/60'}>EN</span>
          </span>
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');

  if (mobileMenuButton && mobileMenu) {
    mobileMenuButton.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });
  }
</script>
