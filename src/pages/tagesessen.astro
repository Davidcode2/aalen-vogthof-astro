---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import { getTranslations } from '../i18n/translations';

const locale = 'de';
const t = getTranslations(locale);

const openingHours = [
  { day: 'Montag-Donnerstag', time: '11:30-14 Uhr' },
  { day: 'Montag-Mittwoch', time: '18:00-22 Uhr' },
  { day: 'Freitag', time: 'Ruhetag (Closed)' },
  { day: 'Samstag', time: '18:00-22 Uhr' },
  { day: 'Sonntag', time: '11:30-14 Uhr' },
];
---

<Layout 
  title="Tagesessen | Landgasthof Vogthof"
  description="Frische Tagesgerichte im Landgasthof Vogthof"
  locale={locale}
>
  <!-- Hero Section -->
  <Hero
    backgroundImage="/images/Tagesessen.jpg"
    headline={t.tagesessen.hero.headline}
    subheadline={t.tagesessen.hero.subheadline}
    ctaText={t.tagesessen.hero.cta}
    ctaLink="https://www.aalen-vogthof.de/aktionen/Tagesessen.pdf"
    height="medium"
    overlayType="gradient"
  />

  <!-- Daily Specials Image Section -->
  <Section background="base" padding="medium">
    <div class="flex flex-col items-center">
      <a 
        href="https://www.aalen-vogthof.de/aktionen/Tagesessen.pdf" 
        target="_blank" 
        rel="noopener noreferrer"
        class="inline-block mb-6 group"
      >
        <img 
          src="/images/Tagesessen.jpg" 
          alt="Tagesessen Karte"
          class="w-full max-w-2xl rounded-sm shadow-medium transition-transform duration-300 group-hover:scale-[1.02]"
        />
      </a>
      <p class="text-secondary font-body text-center">
        {t.tagesessen.download.text}
      </p>
    </div>
  </Section>

  <!-- Opening Hours Section -->
  <Section 
    title={t.tagesessen.hours.title}
    subtitle={t.tagesessen.hours.subtitle}
    background="cream"
    padding="xlarge"
    id="hours"
  >
    <div class="max-w-3xl mx-auto">
      <div class="overflow-x-auto">
        <table class="w-full min-w-[300px] text-left">
          <thead>
            <tr class="border-b border-primary/30">
              <th class="py-4 px-4 font-display text-dark text-lg">{t.tagesessen.hours.dayLabel}</th>
              <th class="py-4 px-4 font-display text-dark text-lg">{t.tagesessen.hours.timeLabel}</th>
            </tr>
          </thead>
          <tbody class="font-body">
            {openingHours.map((row) => (
              <tr class="border-b border-light">
                <td class="py-3 px-4 text-dark">{row.day}</td>
                <td class="py-3 px-4 text-secondary">{row.time}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      
      <div class="mt-6 p-4 bg-secondary-100 border border-light">
        <p class="font-body text-secondary text-center">
          <strong class="text-dark">{t.tagesessen.hours.note}</strong>
        </p>
      </div>
      
      <p class="mt-4 text-center font-body text-muted text-sm">
        {t.tagesessen.hours.subjectToChange}
      </p>
    </div>
  </Section>

  <!-- Closed Dates Section -->
  <Section background="paper" padding="medium">
    <div class="max-w-2xl mx-auto text-center">
      <h3 class="font-display text-2xl font-semibold text-dark mb-4">
        {t.tagesessen.closed.title}
      </h3>
      <div class="p-6 bg-secondary-100 border border-light">
        <p class="font-body text-dark text-lg">
          {t.tagesessen.closed.text}
        </p>
      </div>
    </div>
  </Section>

  <!-- Contact Section -->
  <Section background="base" padding="xlarge">
    <div class="text-center max-w-2xl mx-auto">
      <h3 class="font-display text-3xl font-semibold text-dark mb-6">
        {t.tagesessen.contact.title}
      </h3>
      <div class="p-8 bg-paper shadow-soft border border-light">
        <p class="font-body text-secondary text-xl">
          <strong class="text-primary-600">{t.tagesessen.contact.phone}</strong>
        </p>
      </div>
    </div>
  </Section>

  <!-- Quick Links Section -->
  <Section background="cream" padding="medium">
    <div class="flex flex-wrap justify-center gap-4">
      <a href="/aktionskalender" class="btn-primary">
        → {t.tagesessen.links.menu}
      </a>
      <a href="/impressum" class="btn-secondary">
        → {t.tagesessen.links.imprint}
      </a>
      <a href="/datenschutz" class="btn-secondary">
        → {t.tagesessen.links.privacy}
      </a>
    </div>
  </Section>
</Layout>
