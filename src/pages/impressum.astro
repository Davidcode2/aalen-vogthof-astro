---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import { getTranslations } from '../i18n/translations';

const locale = 'de';
const t = getTranslations(locale);

const legalInfo = {
  owner: 'Reiner Ilg',
  address: 'Bergbaustraße 28/1, 73433 Aalen-Röthardt',
  phone: '+49(0)7361 73688',
  fax: '+49(0)7361 77882',
  email: 'info@aalen-vogthof.de',
  website: 'www.aalen-vogthof.de',
  taxId: 'DE14466139'
};

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'LegalService',
  name: 'Vogthof Landgasthof - Impressum',
  owner: legalInfo.owner,
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Bergbaustraße 28/1',
    addressLocality: 'Aalen-Röthardt',
    postalCode: '73433',
    addressCountry: 'DE'
  },
  telephone: legalInfo.phone,
  faxNumber: legalInfo.fax,
  email: legalInfo.email
};
---

<Layout 
  title="Impressum | Vogthof Landgasthof"
  description="Impressum und rechtliche Informationen des Vogthof Landgasthof in Aalen-Röthardt."
  locale={locale}
>
  <!-- Hero Section -->
  <Section background="surface" padding="medium">
    <div class="text-center">
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-primary mb-4">
        {t.impressum.hero.title}
      </h1>
      <p class="font-body text-lg text-secondary max-w-2xl mx-auto">
        {t.impressum.hero.subtitle}
      </p>
    </div>
  </Section>

  <!-- Legal Content -->
  <Section background="background" padding="large">
    <div class="max-w-4xl mx-auto">
      <!-- Angaben gemäß § 5 TMG -->
      <div class="bg-white rounded-xl shadow-lg p-8 mb-8">
        <h2 class="font-display text-2xl font-bold text-primary mb-6">
          {t.impressum.info.title}
        </h2>
        
        <div class="space-y-4">
          <div>
            <p class="font-body text-sm text-secondary mb-1">{t.impressum.info.owner}:</p>
            <p class="font-body text-lg text-primary font-semibold">
              {legalInfo.owner}
            </p>
          </div>
          
          <div>
            <p class="font-body text-sm text-secondary mb-1">{t.impressum.info.address}:</p>
            <p class="font-body text-lg text-primary">
              {legalInfo.address}
            </p>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <p class="font-body text-sm text-secondary mb-1">{t.impressum.info.phone}:</p>
              <a href={`tel:${legalInfo.phone.replace(/\D/g, '')}`} class="font-body text-lg text-primary hover:text-secondary transition-colors">
                {legalInfo.phone}
              </a>
            </div>
            <div>
              <p class="font-body text-sm text-secondary mb-1">{t.impressum.info.fax}:</p>
              <p class="font-body text-lg text-primary">
                {legalInfo.fax}
              </p>
            </div>
          </div>
          
          <div>
            <p class="font-body text-sm text-secondary mb-1">{t.impressum.info.email}:</p>
            <a href={`mailto:${legalInfo.email}`} class="font-body text-lg text-primary hover:text-secondary transition-colors">
              {legalInfo.email}
            </a>
          </div>
          
          <div>
            <p class="font-body text-sm text-secondary mb-1">{t.impressum.info.website}:</p>
            <a href={`https://${legalInfo.website}`} target="_blank" rel="noopener noreferrer" class="font-body text-lg text-primary hover:text-secondary transition-colors">
              {legalInfo.website}
            </a>
          </div>
          
          <div>
            <p class="font-body text-sm text-secondary mb-1">{t.impressum.info.taxId}:</p>
            <p class="font-body text-lg text-primary">
              {legalInfo.taxId}
            </p>
          </div>
        </div>
      </div>

      <!-- Haftung für Inhalte -->
      <div class="bg-white rounded-xl shadow-lg p-8 mb-8">
        <h2 class="font-display text-2xl font-bold text-primary mb-6">
          {t.impressum.content.title}
        </h2>
        <div class="prose prose-brown max-w-none">
          <p class="font-body text-secondary leading-relaxed">
            {t.impressum.content.text}
          </p>
        </div>
      </div>

      <!-- Haftung für Links -->
      <div class="bg-white rounded-xl shadow-lg p-8 mb-8">
        <h2 class="font-display text-2xl font-bold text-primary mb-6">
          {t.impressum.links.title}
        </h2>
        <div class="prose prose-brown max-w-none">
          <p class="font-body text-secondary leading-relaxed">
            {t.impressum.links.text}
          </p>
        </div>
      </div>

      <!-- Urheber- und Kennzeichenrecht -->
      <div class="bg-white rounded-xl shadow-lg p-8 mb-8">
        <h2 class="font-display text-2xl font-bold text-primary mb-6">
          {t.impressum.copyright.title}
        </h2>
        <div class="prose prose-brown max-w-none">
          <p class="font-body text-secondary leading-relaxed">
            {t.impressum.copyright.text}
          </p>
        </div>
      </div>

      <!-- Datenschutz -->
      <div class="bg-white rounded-xl shadow-lg p-8 mb-8">
        <h2 class="font-display text-2xl font-bold text-primary mb-6">
          {t.impressum.privacy.title}
        </h2>
        <div class="prose prose-brown max-w-none">
          <p class="font-body text-secondary leading-relaxed">
            {t.impressum.privacy.text}
          </p>
        </div>
      </div>

      <!-- Quick Links -->
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/datenschutz"
          class="inline-flex items-center gap-2 px-6 py-3 bg-primary hover:bg-secondary text-white font-semibold rounded-lg shadow-lg hover:shadow-xl transition-all duration-300"
        >
          {t.common.footer.privacy}
        </a>
        <a
          href="/menus"
          class="inline-flex items-center gap-2 px-6 py-3 border-2 border-primary text-primary hover:bg-primary hover:text-white font-semibold rounded-lg transition-all duration-300"
        >
          {t.common.nav.menus}
        </a>
        <a
          href="/tagesessen"
          class="inline-flex items-center gap-2 px-6 py-3 border-2 border-primary text-primary hover:bg-primary hover:text-white font-semibold rounded-lg transition-all duration-300"
        >
          Tagesessen
        </a>
      </div>
    </div>
  </Section>
</Layout>
