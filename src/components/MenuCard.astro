---
interface Props {
  name: string;
  description: string;
  price: string;
  image?: string;
  dietary?: ('vegetarian' | 'vegan' | 'gluten-free' | 'spicy')[];
  category?: string;
}

const {
  name,
  description,
  price,
  image,
  dietary = [],
  category
} = Astro.props;

const dietaryIcons: Record<string, { icon: string; label: string; color: string }> = {
  vegetarian: { icon: '🥬', label: 'Vegetarian', color: 'bg-green-100 text-green-800' },
  vegan: { icon: '🌱', label: 'Vegan', color: 'bg-emerald-100 text-emerald-800' },
  'gluten-free': { icon: '🌾', label: 'Gluten-Free', color: 'bg-amber-100 text-amber-800' },
  spicy: { icon: '🌶️', label: 'Spicy', color: 'bg-red-100 text-red-800' }
};
---

<article class="bg-background-secondary rounded-lg p-4 md:p-6 hover:shadow-md transition-all duration-300 border border-linen hover:border-accent">
  <div class="flex gap-4">
    <!-- Content Side -->
    <div class="flex-1">
      <div class="flex items-start justify-between gap-2 mb-2">
        <h4 class="font-display text-xl font-bold text-primary leading-tight">
          {name}
        </h4>
        <span class="text-primary font-bold text-lg whitespace-nowrap">
          {price}
        </span>
      </div>

      <p class="font-body text-secondary text-sm leading-relaxed mb-3">
        {description}
      </p>

      <!-- Dietary Indicators -->
      {dietary.length > 0 && (
        <div class="flex flex-wrap gap-1">
          {dietary.map((item) => {
            const info = dietaryIcons[item];
            return info ? (
              <span class={`inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs ${info.color}`} title={info.label}>
                {info.icon}
              </span>
            ) : null;
          })}
        </div>
      )}
    </div>

    <!-- Image Side (Optional) -->
    {image && (
      <div class="flex-shrink-0 w-20 h-20 md:w-24 md:h-24 rounded-lg overflow-hidden hidden sm:block">
        <img
          src={image}
          alt={name}
          class="w-full h-full object-cover"
        />
      </div>
    )}
  </div>
</article>
