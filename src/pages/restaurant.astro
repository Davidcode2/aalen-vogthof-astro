---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
import { getTranslations } from '../i18n/translations';

const locale = 'de';
const t = getTranslations(locale);

const heroImage = '/images/restaurant_room_full_length.jpg';

const privateRooms = [
  { key: 'vogtstube', image: '/images/restaurant/r1.jpg' },
  { key: 'braunenberg', image: '/images/restaurant/r2.jpg' },
  { key: 'beerGarden', image: '/images/restaurant/beergarden.jpg' },
] as const;
---

<Layout 
  title="Restaurant | Vogthof Landgasthof"
  description="Traditionelle schwäbische Gastfreundschaft trifft auf elegante Küche."
  locale={locale}
>
  <!-- Hero Section -->
  <Hero
    headline={t.restaurant.hero.headline}
    subheadline={t.restaurant.hero.subheadline}
    backgroundImage={heroImage}
    ctaText={t.restaurant.hero.ctaPrimary}
    ctaLink="/menus"
    ctaSecondaryText={t.restaurant.hero.ctaSecondary}
    ctaSecondaryLink="#contact"
    height="large"
  />

  <!-- Introduction Section -->
  <Section
    title={t.restaurant.heritage.title}
    subtitle={t.restaurant.heritage.subtitle}
    background="background"
  >
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div class="prose prose-lg text-secondary">
        <p class="mb-6">
          {t.restaurant.heritage.paragraph1}
        </p>
        <p class="mb-6">
          {t.restaurant.heritage.paragraph2}
        </p>
        <p>
          {t.restaurant.heritage.paragraph3}
        </p>
      </div>
      <div class="relative">
        <img
          src="/images/restaurant/r2.jpg"
          alt="Restaurant interior"
          class="shadow-xl w-full"
        />
      </div>
    </div>
  </Section>

  <!-- Kitchen Philosophy Section -->
  <Section
    title={t.restaurant.philosophy.title}
    subtitle={t.restaurant.philosophy.subtitle}
    background="background-secondary"
  >
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div class="order-2 md:order-1 relative">
        <img
          src="/images/kitchen/cu.jpg"
          alt="Chef in the kitchen"
          class="shadow-xl w-full"
        />
      </div>
      <div class="order-1 md:order-2 prose prose-lg text-secondary">
        <p class="mb-6">
          {t.restaurant.philosophy.paragraph1}
        </p>
        <p class="mb-6">
          {t.restaurant.philosophy.paragraph2}
        </p>
        <p class="mb-4">
          {t.restaurant.philosophy.paragraph3}
        </p>
      </div>
    </div>
  </Section>

  <!-- Chef Information -->
  <Section
    title={t.restaurant.chefs.title}
    subtitle={t.restaurant.chefs.subtitle}
    background="surface"
  >
    <div class="grid lg:grid-cols-2 gap-8 items-center">
      <!-- Single Image Showing Both Chefs -->
      <div class="relative overflow-hidden shadow-xl">
        <img
          src="/images/chefs.jpg"
          alt="Reiner Ilg und Johannes Hänle"
          class="w-full h-full object-cover"
        />
      </div>

      <!-- Chef Info Cards -->
      <div class="space-y-6">
        <!-- Reiner Ilg -->
        <div class="bg-white p-6 shadow-md">
          <div class="flex items-start gap-4">
            <div class="flex-1">
              <h3 class="font-display text-xl font-bold text-primary mb-1">
                {t.restaurant.chefs.chef1.name}
              </h3>
              <p class="text-sm font-semibold text-accent-600 mb-3">
                {t.restaurant.chefs.chef1.title}
              </p>
              <p class="text-secondary leading-relaxed">
                {t.restaurant.chefs.chef1.description}
              </p>
            </div>
          </div>
        </div>

        <!-- Johannes Hänle -->
        <div class="bg-white p-6 shadow-md">
          <div class="flex items-start gap-4">
            <div class="flex-1">
              <h3 class="font-display text-xl font-bold text-primary mb-1">
                {t.restaurant.chefs.chef2.name}
              </h3>
              <p class="text-sm font-semibold text-accent-600 mb-3">
                {t.restaurant.chefs.chef2.title}
              </p>
              <p class="text-secondary leading-relaxed">
                {t.restaurant.chefs.chef2.description}
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- Private Rooms Section -->
  <Section
    title={t.restaurant.privateRooms.title}
    subtitle={t.restaurant.privateRooms.subtitle}
    background="background"
  >
    <div class="grid md:grid-cols-3 gap-8">
      {privateRooms.map((room) => (
        <Card
          title={t.restaurant.privateRooms[room.key].name}
          description={t.restaurant.privateRooms[room.key].description}
          image={room.image}
          linkText={`Kapazität: ${t.restaurant.privateRooms[room.key].capacity}`}
          hoverEffect="lift"
        />
      ))}
    </div>

    <div class="text-center mt-12">
      <p class="text-secondary text-lg mb-6">
        {t.restaurant.privateRooms.contactText}
      </p>
      <a
        href="tel:07361-73688"
        class="inline-block px-8 py-4 bg-primary hover:bg-primary-light text-white font-semibold transition-all duration-300 shadow-lg hover:shadow-xl"
      >
        {t.restaurant.privateRooms.cta}
      </a>
    </div>
  </Section>

  <!-- Beer Garden Highlight -->
  <Section
    title={t.restaurant.beerGarden.title}
    subtitle={t.restaurant.beerGarden.subtitle}
    background="background-secondary"
    id="beer-garden"
  >
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div class="prose prose-lg text-secondary">
        <p class="mb-6">
          {t.restaurant.beerGarden.paragraph1}
        </p>
        <p class="mb-6">
          {t.restaurant.beerGarden.paragraph2}
        </p>
        <p>
          {t.restaurant.beerGarden.paragraph3}
        </p>
      </div>
      <div class="relative">
        <img
          src="/images/restaurant/beergarden.jpg"
          alt="Biergarten"
          class="shadow-xl w-full"
        />
      </div>
    </div>
  </Section>

  <!-- Contact/CTA Section -->
  <Section
    title={t.restaurant.reserve.title}
    subtitle={t.restaurant.reserve.subtitle}
    background="surface"
    id="contact"
  >
    <div class="text-center max-w-2xl mx-auto">
      <div class="grid md:grid-cols-2 gap-8 mb-8">
        <div class="bg-white p-6 shadow-md">
          <h3 class="font-bold text-primary mb-2">{t.restaurant.reserve.phone}</h3>
          <p class="text-secondary">07361-73688</p>
        </div>
        <div class="bg-white p-6 shadow-md">
          <h3 class="font-bold text-primary mb-2">{t.restaurant.reserve.hours}</h3>
          <p class="text-secondary">
            Mo-Do: 11:30-14:00 & 18:00-22:00<br />
            Fr: Ruhetag<br />
            Sa: 18:00-22:00<br />
            So: 11:30-14:00
          </p>
        </div>
      </div>
      <a
        href="/menus"
        class="inline-block px-8 py-4 bg-secondary hover:bg-secondary-light text-white font-semibold transition-all duration-300 shadow-lg hover:shadow-xl"
      >
        {t.restaurant.reserve.cta}
      </a>
    </div>
  </Section>
</Layout>
