---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
import { getTranslations } from '../i18n/translations';

const locale = 'de';
const t = getTranslations(locale);

const fitnessHighlights = [
  { key: 'hiking', image: '/images/bucher-stausee.jpg' },
  { key: 'biking', image: '/images/radler-schloss-ellwangen.jpg' },
  { key: 'swimming', image: '/images/bucher-stausee.jpg' },
  { key: 'winter', image: '/images/hiking_in_nature.jpg' },
] as const;

const wellnessHighlights = [
  { key: 'stollen', image: '/images/limes-thermen.jpg' },
  { key: 'thermen', image: '/images/limes-thermen.jpg' },
] as const;

const cultureHighlights = [
  { key: 'aalen', image: '/images/radler-schloss-ellwangen.jpg' },
  { key: 'ellwangen', image: '/images/radler-schloss-ellwangen.jpg' },
  { key: 'neresheim', image: '/images/radler-schloss-ellwangen.jpg' },
  { key: 'dinkelsbuehl', image: '/images/radler-schloss-ellwangen.jpg' },
  { key: 'rothenburg', image: '/images/radler-schloss-ellwangen.jpg' },
  { key: 'cities', image: '/images/radler-schloss-ellwangen.jpg' },
] as const;
---

<Layout 
  title="Aktivitäten - Landgasthof Vogthof"
  description="Entdecken Sie die perfekte Mischung aus Outdoor-Abenteuer, Wellness und Kultur rund um unseren historischen Landgasthof."
  locale={locale}
>
  <Hero
    headline={t.activities.hero.headline}
    subheadline={t.activities.hero.subheadline}
    backgroundImage="/images/hotel1.jpg"
    height="large"
  />

  <Section
    title={t.activities.movement.title}
    subtitle={t.activities.movement.subtitle}
    background="background"
  >
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {fitnessHighlights.map((highlight) => (
        <Card
          title={t.activities.movement[highlight.key].title}
          description={t.activities.movement[highlight.key].description}
          image={highlight.image}
          hoverEffect="lift"
        />
      ))}
    </div>
  </Section>

  <Section
    title={t.activities.wellness.title}
    subtitle={t.activities.wellness.subtitle}
    background="background-secondary"
  >
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {wellnessHighlights.map((highlight) => (
        <Card
          title={t.activities.wellness[highlight.key].title}
          description={t.activities.wellness[highlight.key].description}
          image={highlight.image}
          hoverEffect="lift"
        />
      ))}
    </div>
  </Section>

  <Section
    title={t.activities.culture.title}
    subtitle={t.activities.culture.subtitle}
    background="surface"
  >
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {cultureHighlights.map((highlight) => (
        <Card
          title={t.activities.culture[highlight.key].title}
          description={t.activities.culture[highlight.key].description}
          image={highlight.image}
          hoverEffect="lift"
        />
      ))}
    </div>
  </Section>

  <Section
    title={t.activities.cta.title}
    subtitle={t.activities.cta.subtitle}
    background="background"
    padding="medium"
  >
    <div class="flex flex-wrap justify-center gap-4">
      <a
        href="/contact"
        class="inline-block px-8 py-4 bg-primary hover:bg-primary-light text-white font-semibold rounded-md transition-all duration-300 shadow-lg hover:shadow-xl"
      >
        {t.activities.cta.button}
      </a>
    </div>
  </Section>
</Layout>
