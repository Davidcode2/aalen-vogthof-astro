---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import { getTranslations } from '../i18n/translations';

const locale = 'de';
const t = getTranslations(locale);

const heroImage = '/images/eat/mushroom_main_course.jpg';

const menuCategories = [
  { key: 'appetizers', icon: '🥗' },
  { key: 'mains', icon: '🍽️' },
  { key: 'desserts', icon: '🍰' },
  { key: 'drinks', icon: '🍷' },
] as const;
---

<Layout 
  title="Speisekarte | Landgasthof Vogthof"
  description="Frische, saisonale Zutaten mit Leidenschaft zubereitet."
  locale={locale}
>
  <!-- Hero Section -->
  <Hero
    headline={t.menus.hero.headline}
    subheadline={t.menus.hero.subheadline}
    backgroundImage={heroImage}
    ctaText={t.menus.hero.ctaPrimary}
    ctaLink="#daily-specials"
    ctaSecondaryText={t.menus.hero.ctaSecondary}
    ctaSecondaryLink="/restaurant"
    height="large"
    overlayType="gradient"
  />

  <!-- Introduction -->
  <Section
    title={t.menus.seasonal.title}
    subtitle={t.menus.seasonal.subtitle}
    background="base"
    padding="xlarge"
  >
    <div class="max-w-4xl mx-auto text-center">
      <blockquote class="text-xl italic text-secondary mb-8 font-body">
        "{t.menus.seasonal.quote}"
        <cite class="block text-sm mt-2 not-italic text-muted">— {t.menus.seasonal.quoteAuthor}</cite>
      </blockquote>
      
      <div class="font-body text-lg text-secondary leading-relaxed">
        <p class="mb-6">
          {t.menus.seasonal.paragraph1}
        </p>
        <p class="mb-6">
          {t.menus.seasonal.paragraph2}
        </p>
        <p>
          {t.menus.seasonal.paragraph3}
        </p>
      </div>
    </div>
  </Section>

  <!-- Menu Categories Section -->
  <Section
    title={t.menus.categories.title}
    subtitle={t.menus.categories.subtitle}
    background="cream"
    padding="xlarge"
  >
    <div class="grid md:grid-cols-2 gap-8">
      {menuCategories.map((category) => (
        <article class="bg-paper p-8 shadow-subtle border border-light hover:shadow-soft transition-all duration-500">
          <div class="flex items-center mb-6">
            <span class="text-4xl mr-4">{category.icon}</span>
            <h3 class="font-display text-2xl font-semibold text-dark">{t.menus.categories[category.key].name}</h3>
          </div>
          <p class="text-secondary mb-6">{t.menus.categories[category.key].description}</p>
          <ul class="space-y-4">
            {t.menus.categories[category.key].items.map((item) => (
              <li class="flex justify-between items-start border-b border-light pb-3 last:border-0">
                <div>
                  <span class="font-semibold text-dark">{item.name}</span>
                  <p class="text-sm text-muted">{item.desc}</p>
                </div>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </Section>

  <!-- Daily Specials Section -->
  <Section
    title={t.menus.dailySpecials.title}
    subtitle={t.menus.dailySpecials.availability}
    background="paper"
    padding="xlarge"
    id="daily-specials"
  >
    <div class="max-w-4xl mx-auto">
      <div class="bg-cream p-8 lg:p-10 border border-light shadow-soft">
        <div class="flex items-start gap-4 mb-8">
          <span class="text-5xl">🍽️</span>
          <div>
            <h3 class="font-display text-2xl font-semibold text-dark">{t.menus.dailySpecials.title}</h3>
            <p class="text-secondary">{t.menus.dailySpecials.availability}</p>
          </div>
        </div>
        
        <div class="font-body text-secondary">
          <p class="mb-4">
            {t.menus.dailySpecials.description}
          </p>
          <ul class="list-disc list-inside space-y-2 mb-6 ml-4">
            {t.menus.dailySpecials.includes.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
          <p>
            {t.menus.dailySpecials.cta}
          </p>
        </div>
      </div>
    </div>
  </Section>

  <!-- Allergen Information -->
  <Section
    title={t.menus.allergen.title}
    subtitle={t.menus.allergen.subtitle}
    background="base"
    padding="xlarge"
  >
    <div class="max-w-3xl mx-auto text-center">
      <div class="bg-paper p-8 shadow-soft border border-light mb-8">
        <p class="text-secondary text-lg mb-4">
          {t.menus.allergen.text1}
        </p>
        <p class="text-secondary">
          {t.menus.allergen.text2}
        </p>
      </div>
    </div>
  </Section>

  <!-- View Full Menu CTA -->
  <Section
    title={t.menus.cta.title}
    subtitle={t.menus.cta.subtitle}
    background="cream"
    padding="xlarge"
  >
    <div class="text-center">
      <div class="flex flex-wrap justify-center gap-4 mb-8">
        <a href="/restaurant" class="btn-primary">
          {t.menus.cta.ctaRestaurant}
        </a>
        <a href="tel:07361-73688" class="btn-secondary">
          {t.menus.cta.ctaCall}
        </a>
      </div>
      <p class="text-secondary">
        {t.menus.cta.hours}
      </p>
    </div>
  </Section>
</Layout>
