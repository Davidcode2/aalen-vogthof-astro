---
interface Props {
  title: string;
  subtitle?: string;
  background?: 'background' | 'background-secondary' | 'surface' | 'white' | 'transparent';
  padding?: 'none' | 'small' | 'medium' | 'large';
  id?: string;
}

const {
  title,
  subtitle,
  background = 'background',
  padding = 'large',
  id
} = Astro.props;

const backgroundClasses = {
  background: 'bg-background',
  'background-secondary': 'bg-background-secondary',
  surface: 'bg-surface',
  white: 'bg-white',
  transparent: 'bg-transparent'
};

const paddingClasses = {
  none: '',
  small: 'py-8',
  medium: 'py-16',
  large: 'py-20'
};
---

<section
  id={id}
  class={`${backgroundClasses[background]} ${paddingClasses[padding]} w-full`}
>
  <div class="container mx-auto px-4">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold text-primary mb-4">
        {title}
      </h2>

      {subtitle && (
        <p class="font-body text-lg text-secondary max-w-2xl mx-auto">
          {subtitle}
        </p>
      )}

      <!-- Decorative Line -->
      <div class="w-24 h-1 bg-primary mx-auto mt-6 rounded-full"></div>
    </div>

    <!-- Content Slot -->
    <slot />
  </div>
</section>
