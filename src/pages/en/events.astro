---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Section from '../../components/Section.astro';
import Card from '../../components/Card.astro';
import { getTranslations } from '../../i18n/translations';

const locale = 'en';
const t = getTranslations(locale);

const venueImages = [
  { src: '/images/f1.jpg', alt: 'Festive atmosphere' },
  { src: '/images/f2.jpg', alt: 'Celebration setup' },
  { src: '/images/f3.jpg', alt: 'Event gathering' },
  { src: '/images/f4.jpg', alt: 'Festive decorations' },
  { src: '/images/f5.jpg', alt: 'Celebration moments' },
];

const capacityOptions = [
  { key: 'restaurant', icon: '👥' },
  { key: 'vogtstube', icon: '🪑' },
  { key: 'braunenberg', icon: '🍽️' },
] as const;

const serviceFeatures = [
  { key: 'menu', icon: '🍴' },
  { key: 'decoration', icon: '🎨' },
  { key: 'consultation', icon: '💬' },
] as const;
---

<Layout 
  title="Events & Celebrations - Landgasthof Vogthof"
  description="Celebrate with us! Whether family celebration or company party – the Vogthof is always a good choice!"
  locale={locale}
>
  <Hero
    headline={t.events.hero.headline}
    subheadline={t.events.hero.subheadline}
    backgroundImage="/images/f1.jpg"
    height="large"
  />

  <Section
    title={t.events.intro.title}
    subtitle={t.events.intro.subtitle}
    background="cream"
  >
    <div class="max-w-4xl mx-auto">
      <p class="text-lg text-[#5C4033] leading-relaxed mb-8">
        {t.events.intro.text}
      </p>
    </div>
  </Section>

  <Section
    title={t.events.capacity.title}
    subtitle={t.events.capacity.subtitle}
    background="old-lace"
  >
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {capacityOptions.map((option) => (
        <Card
          title={t.events.capacity[option.key].title}
          description={`${t.events.capacity[option.key].capacity} - ${t.events.capacity[option.key].desc}`}
          image="/images/f1.jpg"
          hoverEffect="lift"
        />
      ))}
    </div>
  </Section>

  <Section
    title={t.events.services.title}
    subtitle={t.events.services.subtitle}
    background="antique"
  >
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {serviceFeatures.map((feature) => (
        <div class="bg-white rounded-lg p-6 shadow-md text-center">
          <div class="text-4xl mb-4">{feature.icon}</div>
          <h3 class="font-['Playfair_Display',Georgia,serif] text-xl font-bold text-[#2C1810] mb-2">
            {t.events.services[feature.key].title}
          </h3>
          <p class="font-['Open_Sans',Arial,sans-serif] text-[#5C4033]">
            {t.events.services[feature.key].description}
          </p>
        </div>
      ))}
    </div>
  </Section>

  <Section
    title={t.events.gallery.title}
    subtitle={t.events.gallery.subtitle}
    background="cream"
  >
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">
      {venueImages.map((img) => (
        <div class="relative overflow-hidden rounded-lg aspect-square group">
          <img
            src={img.src}
            alt={img.alt}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
          />
          <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-all duration-300"></div>
        </div>
      ))}
    </div>
  </Section>

  <Section
    title={t.events.planning.title}
    subtitle={t.events.planning.subtitle}
    background="old-lace"
    padding="large"
  >
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-lg text-[#5C4033] leading-relaxed mb-8">
        {t.events.planning.text}
      </p>
      
      <div class="bg-white rounded-lg p-8 shadow-lg border-t-4 border-[#8B4513]">
        <h3 class="font-['Playfair_Display',Georgia,serif] text-2xl font-bold text-[#2C1810] mb-4">
          {t.events.planning.title}
        </h3>
        <p class="text-[#5C4033] mb-6">
          Do you have more questions? Please don't hesitate to contact us.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="tel:07361-73688"
            class="inline-block px-6 py-3 bg-[#8B4513] hover:bg-[#A0522D] text-white font-semibold rounded-md transition-all duration-300"
          >
            {t.events.planning.ctaCall}
          </a>
          <a
            href="mailto:info@aalen-vogthof.de"
            class="inline-block px-6 py-3 border-2 border-[#8B4513] text-[#8B4513] hover:bg-[#8B4513] hover:text-white font-semibold rounded-md transition-all duration-300"
          >
            {t.events.planning.ctaEmail}
          </a>
        </div>
      </div>
    </div>
  </Section>
</Layout>
