---
import Section from './Section.astro';

interface Props {
  title: string;
  subtitle?: string;
  phoneLabel?: string;
  hoursLabel?: string;
  openingHours?: string[];
  ctaText: string;
  ctaLink: string;
  phoneNumber?: string;
  variant?: 'cards' | 'button';
  background?: 'background' | 'background-secondary' | 'surface';
  id?: string;
}

const {
  title,
  subtitle,
  phoneLabel = 'Telefon',
  hoursLabel = 'Öffnungszeiten',
  openingHours = [],
  ctaText,
  ctaLink,
  phoneNumber = '07361-73688',
  variant = 'cards',
  background = 'background',
  id = 'contact',
} = Astro.props;
---

{variant === 'cards' && (
  <Section id={id} title={title} background={background}>
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
        <div class="bg-white p-8 shadow-lg text-center">
          <span class="text-4xl mb-4 block">📞</span>
          <h3 class="font-display text-xl font-bold text-primary mb-2">{phoneLabel}</h3>
          <p class="font-body text-secondary text-lg">{phoneNumber}</p>
        </div>
        <div class="bg-white p-8 shadow-lg text-center">
          <span class="text-4xl mb-4 block">🕐</span>
          <h3 class="font-display text-xl font-bold text-primary mb-2">{hoursLabel}</h3>
          <p class="font-body text-secondary">
            {openingHours.map((line, index) => (
              <>
                {line}
                {index < openingHours.length - 1 && <br />}
              </>
            ))}
          </p>
        </div>
      </div>
      
      <div class="text-center">
        <a
          href={ctaLink}
          class="inline-block px-8 py-4 bg-secondary hover:bg-secondary-light text-white font-semibold transition-colors duration-300 text-lg"
        >
          {ctaText}
        </a>
      </div>
    </div>
  </Section>
)}

{variant === 'button' && (
  <Section id={id} title={title} subtitle={subtitle} background={background} padding="medium">
    <div class="flex flex-wrap justify-center gap-4">
      <a
        href={ctaLink}
        class="inline-block px-8 py-4 bg-primary hover:bg-primary-light text-white font-semibold rounded-md transition-all duration-300 shadow-lg hover:shadow-xl"
      >
        {ctaText}
      </a>
    </div>
  </Section>
)}
