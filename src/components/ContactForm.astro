---
interface Props {
  submitUrl?: string;
  buttonText?: string;
}

const {
  submitUrl = '/api/contact',
  buttonText = 'Send Message'
} = Astro.props;
---

<form class="bg-white shadow-lg p-6 md:p-8" action={submitUrl} method="POST">
  <!-- Form Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
    <!-- Name Field -->
    <div class="space-y-2">
      <label for="name" class="block font-body text-sm font-semibold text-primary">
        Name *
      </label>
      <input
        type="text"
        id="name"
        name="name"
        required
        placeholder="Your full name"
        class="w-full px-4 py-3 border border-accent-light focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent font-body transition-all duration-300"
      />
    </div>

    <!-- Email Field -->
    <div class="space-y-2">
      <label for="email" class="block font-body text-sm font-semibold text-primary">
        Email *
      </label>
      <input
        type="email"
        id="email"
        name="email"
        required
        placeholder="your@email.com"
        class="w-full px-4 py-3 border border-accent-light focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent font-body transition-all duration-300"
      />
    </div>

    <!-- Phone Field -->
    <div class="space-y-2 md:col-span-2">
      <label for="phone" class="block font-body text-sm font-semibold text-primary">
        Phone Number
      </label>
      <input
        type="tel"
        id="phone"
        name="phone"
        placeholder="+49 (optional)"
        class="w-full px-4 py-3 border border-accent-light focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent font-body transition-all duration-300"
      />
    </div>
  </div>

  <!-- Message Field -->
  <div class="space-y-2 mb-6">
    <label for="message" class="block font-body text-sm font-semibold text-primary">
      Message *
    </label>
    <textarea
      id="message"
      name="message"
      required
      rows="5"
      placeholder="How can we help you?"
      class="w-full px-4 py-3 border border-accent-light focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent font-body transition-all duration-300 resize-none"
    ></textarea>
  </div>

  <!-- GDPR Consent -->
  <div class="flex items-start gap-3 mb-8">
    <input
      type="checkbox"
      id="gdpr"
      name="gdpr"
      required
      class="mt-1 w-5 h-5 text-primary border-accent-light rounded focus:ring-primary cursor-pointer"
    />
    <label for="gdpr" class="font-body text-sm text-secondary leading-relaxed">
      I agree to the processing of my personal data in accordance with the <a href="/privacy" class="text-primary hover:text-secondary underline">Privacy Policy</a>. This is required to respond to your inquiry. *
    </label>
  </div>

  <!-- Submit Button -->
  <div class="text-center">
    <button
      type="submit"
      class="inline-block px-8 py-4 bg-primary hover:bg-secondary text-white font-semibold shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-0.5"
    >
      {buttonText}
    </button>
  </div>

  <!-- Success Message (hidden by default) -->
  <div id="form-success" class="hidden mt-4 p-4 bg-forest/10 border border-forest/30">
    <p class="text-forest font-body text-center">
      Thank you for your message! We will get back to you soon.
    </p>
  </div>
</form>
