---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import { getTranslations } from '../i18n/translations';

const locale = 'de';
const t = getTranslations(locale);

const seasons = [
  { key: 'spring', icon: '🍃' },
  { key: 'summer', icon: '☀️' },
  { key: 'autumn', icon: '🍂' },
  { key: 'winter', icon: '❄️' },
] as const;

const openingHours = [
  { day: 'Montag-Donnerstag', time: '11:30-14 Uhr' },
  { day: 'Montag-Mittwoch', time: '18:00-22 Uhr' },
  { day: 'Freitag', time: 'Ruhetag (Closed)' },
  { day: 'Samstag', time: '18:00-22 Uhr' },
  { day: 'Sonntag', time: '11:30-14 Uhr' },
];
---

<Layout 
  title="Speisekarte | Landgasthof Vogthof"
  description="Saisonale Speisekarte und Kalender im Landgasthof Vogthof"
  locale={locale}
>
  <!-- Hero Section -->
  <Hero
    backgroundImage="/images/Aktionskalender.jpg"
    headline={t.aktionskalender.hero.headline}
    subheadline={t.aktionskalender.hero.subheadline}
    ctaText={t.aktionskalender.hero.cta}
    ctaLink="https://www.aalen-vogthof.de/aktionen/Aktionskalender.pdf"
    height="medium"
    overlayType="gradient"
  />

  <!-- Menu Image Section -->
  <Section background="base" padding="medium">
    <div class="flex flex-col items-center">
      <a 
        href="https://www.aalen-vogthof.de/aktionen/Aktionskalender.pdf" 
        target="_blank" 
        rel="noopener noreferrer"
        class="inline-block mb-6 group"
      >
        <img 
          src="/images/Aktionskalender.jpg" 
          alt="Speisekarte"
          class="w-full max-w-2xl rounded-sm shadow-medium transition-transform duration-300 group-hover:scale-[1.02]"
        />
      </a>
      <p class="text-secondary font-body text-center">
        {t.aktionskalender.download.text}
      </p>
    </div>
  </Section>

  <!-- Seasonal Information Section -->
  <Section 
    title={t.aktionskalender.seasonal.title}
    subtitle={t.aktionskalender.seasonal.subtitle}
    background="cream"
    padding="xlarge"
  >
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {seasons.map((season) => (
          <div class="p-6 bg-paper shadow-subtle border border-light hover:shadow-soft transition-all duration-500">
            <div class="flex items-center mb-4">
              <span class="text-3xl mr-3">{season.icon}</span>
              <h4 class="font-display text-xl font-semibold text-dark">
                {t.aktionskalender.seasonal[season.key].title}
              </h4>
            </div>
            <p class="font-body text-secondary">
              {t.aktionskalender.seasonal[season.key].description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </Section>

  <!-- Opening Hours Section -->
  <Section 
    title={t.aktionskalender.hours.title}
    subtitle={t.aktionskalender.hours.subtitle}
    background="paper"
    padding="xlarge"
    id="hours"
  >
    <div class="max-w-3xl mx-auto">
      <div class="overflow-x-auto">
        <table class="w-full min-w-[300px] text-left">
          <thead>
            <tr class="border-b border-primary/30">
              <th class="py-4 px-4 font-display text-dark text-lg">{t.aktionskalender.hours.dayLabel}</th>
              <th class="py-4 px-4 font-display text-dark text-lg">{t.aktionskalender.hours.timeLabel}</th>
            </tr>
          </thead>
          <tbody class="font-body">
            {openingHours.map((row) => (
              <tr class="border-b border-light">
                <td class="py-3 px-4 text-dark">{row.day}</td>
                <td class="py-3 px-4 text-secondary">{row.time}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      
      <div class="mt-6 p-4 bg-secondary-100 border border-light">
        <p class="font-body text-secondary text-center">
          <strong class="text-dark">{t.aktionskalender.hours.note}</strong>
        </p>
      </div>
      
      <p class="mt-4 text-center font-body text-muted text-sm">
        {t.aktionskalender.hours.subjectToChange}
      </p>
    </div>
  </Section>

  <!-- Closed Dates Section -->
  <Section background="base" padding="medium">
    <div class="max-w-2xl mx-auto text-center">
      <h3 class="font-display text-2xl font-semibold text-dark mb-4">
        {t.aktionskalender.closed.title}
      </h3>
      <div class="p-6 bg-secondary-100 border border-light">
        <p class="font-body text-dark text-lg">
          {t.aktionskalender.closed.text}
        </p>
      </div>
    </div>
  </Section>

  <!-- Contact Section -->
  <Section background="cream" padding="xlarge">
    <div class="text-center max-w-2xl mx-auto">
      <h3 class="font-display text-3xl font-semibold text-dark mb-6">
        {t.aktionskalender.contact.title}
      </h3>
      <div class="p-8 bg-paper shadow-soft border border-light">
        <p class="font-body text-secondary text-xl">
          <strong class="text-primary-600">{t.aktionskalender.contact.phone}</strong>
        </p>
      </div>
    </div>
  </Section>

  <!-- Quick Links Section -->
  <Section background="paper" padding="medium">
    <div class="flex flex-wrap justify-center gap-4">
      <a href="/tagesessen" class="btn-primary">
        → {t.aktionskalender.links.daily}
      </a>
      <a href="/impressum" class="btn-secondary">
        → {t.aktionskalender.links.imprint}
      </a>
      <a href="/datenschutz" class="btn-secondary">
        → {t.aktionskalender.links.privacy}
      </a>
    </div>
  </Section>
</Layout>
