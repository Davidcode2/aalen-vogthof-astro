---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
import { getTranslations } from '../i18n/translations';

const locale = 'de';
const t = getTranslations(locale);

const venueImages = [
  { src: '/images/wedding_preparations.jpg', alt: 'Festliche Atmosphäre' },
  { src: '/images/wedding_table.jpg', alt: 'Feier-Aufbau' },
  { src: '/images/restaurant_room_empty_red_decoration.jpg', alt: 'Veranstaltung' },
  { src: '/images/restaurant_room_full_length.jpg', alt: 'Festliche Dekoration' },
  { src: '/images/restaurant_empty_rose_decoration.jpg', alt: 'Feier-Momente' },
];

const capacityOptions = [
  { key: 'restaurant', icon: '👥', image: '/images/restaurant_room_full_length.jpg' },
  { key: 'vogtstube', icon: '🪑', image: '/images/restaurant/vogtstube.jpg' },
  { key: 'braunenberg', icon: '🍽️', image: '/images/restaurant/braunenbergstube.jpg' },
] as const;

const serviceFeatures = [
  { key: 'menu', icon: '🍴' },
  { key: 'decoration', icon: '🎨' },
  { key: 'consultation', icon: '💬' },
] as const;
---

<Layout 
  title="Veranstaltungen & Feiern | Landgasthof Vogthof"
  description="Feiern Sie bei uns! Ob Familienfest oder Betriebsfeier – der Vogthof ist immer eine gute Wahl!"
  locale={locale}
>
  <Hero
    headline={t.events.hero.headline}
    subheadline={t.events.hero.subheadline}
    backgroundImage="/images/wedding_table.jpg"
    height="large"
    overlayType="gradient"
  />

  <Section
    title={t.events.intro.title}
    subtitle={t.events.intro.subtitle}
    background="base"
    padding="xlarge"
  >
    <div class="max-w-4xl mx-auto text-center">
      <p class="font-body text-lg text-secondary leading-relaxed mb-8">
        {t.events.intro.text}
      </p>
    </div>
  </Section>

  <Section
    title={t.events.capacity.title}
    subtitle={t.events.capacity.subtitle}
    background="cream"
    padding="xlarge"
  >
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {capacityOptions.map((option) => (
        <Card
          title={t.events.capacity[option.key].title}
          description={`${t.events.capacity[option.key].capacity} - ${t.events.capacity[option.key].desc}`}
          image={option.image}
          hoverEffect="lift"
        />
      ))}
    </div>
  </Section>

  <Section
    title={t.events.services.title}
    subtitle={t.events.services.subtitle}
    background="paper"
    padding="xlarge"
  >
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {serviceFeatures.map((feature) => (
        <div class="bg-paper p-8 shadow-subtle text-center hover:shadow-soft transition-all duration-500">
          <div class="text-4xl mb-4">{feature.icon}</div>
          <h3 class="font-display text-xl font-semibold text-dark mb-2">
            {t.events.services[feature.key].title}
          </h3>
          <p class="font-body text-secondary">
            {t.events.services[feature.key].description}
          </p>
        </div>
      ))}
    </div>
  </Section>

  <Section
    title={t.events.gallery.title}
    subtitle={t.events.gallery.subtitle}
    background="base"
    padding="xlarge"
  >
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">
      {venueImages.map((img) => (
        <div class="relative overflow-hidden aspect-square group">
          <img
            src={img.src}
            alt={img.alt}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
          />
          <div class="absolute inset-0 bg-primary-900/0 group-hover:bg-primary-900/30 transition-all duration-300"></div>
        </div>
      ))}
    </div>
  </Section>

  <Section
    title={t.events.planning.title}
    subtitle={t.events.planning.subtitle}
    background="cream"
    padding="xlarge"
  >
    <div class="max-w-3xl mx-auto text-center">
      <p class="font-body text-lg text-secondary leading-relaxed mb-8">
        {t.events.planning.text}
      </p>
      
      <div class="">
        <h3 class="font-display text-2xl font-semibold text-dark mb-4">
          {t.events.planning.contactTitle}
        </h3>
        <p class="text-secondary mb-6">
          {t.events.planning.contactText}
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="tel:07361-73688" class="btn-primary">
            {t.events.planning.ctaCall}
          </a>
          <a href="/contact" class="btn-secondary">
            {t.events.planning.ctaEmail}
          </a>
        </div>
      </div>
    </div>
  </Section>
</Layout>
