---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import { getTranslations } from '../i18n/translations';

const locale = 'de';
const t = getTranslations(locale);

const openingHours = [
  { day: 'Montag-Donnerstag', time: '11:30-14 Uhr' },
  { day: 'Montag-Mittwoch', time: '18:00-22 Uhr' },
  { day: 'Freitag', time: 'Ruhetag (Closed)' },
  { day: 'Samstag', time: '18:00-22 Uhr' },
  { day: 'Sonntag', time: '11:30-14 Uhr' },
];
---

<Layout 
  title="Tagesessen | Vogthof Landgasthof"
  description="Frische Tagesgerichte im Vogthof Landgasthof"
  locale={locale}
>
  <!-- Hero Section -->
  <Hero
    backgroundImage="/images/Tagesessen.jpg"
    headline={t.tagesessen.hero.headline}
    subheadline={t.tagesessen.hero.subheadline}
    ctaText={t.tagesessen.hero.cta}
    ctaLink="https://www.aalen-vogthof.de/aktionen/Tagesessen.pdf"
    height="medium"
  />

  <!-- Daily Specials Image Section -->
  <Section background="background" padding="medium">
    <div class="flex flex-col items-center">
      <a 
        href="https://www.aalen-vogthof.de/aktionen/Tagesessen.pdf" 
        target="_blank" 
        rel="noopener noreferrer"
        class="inline-block mb-6 group"
      >
        <img 
          src="/images/Tagesessen.jpg" 
          alt="Tagesessen Karte"
          class="w-full max-w-2xl rounded-lg shadow-xl transition-transform duration-300 group-hover:scale-[1.02]"
        />
      </a>
      <p class="text-secondary font-body text-center">
        {t.tagesessen.download.text}
      </p>
    </div>
  </Section>

  <!-- Opening Hours Section -->
  <Section 
    title={t.tagesessen.hours.title}
    subtitle={t.tagesessen.hours.subtitle}
    background="background-secondary"
    padding="medium"
    id="hours"
  >
    <div class="max-w-3xl mx-auto">
      <div class="overflow-x-auto">
        <table class="w-full min-w-[300px] text-left">
          <thead>
            <tr class="border-b border-primary/30">
              <th class="py-4 px-4 font-display text-primary text-lg">{t.tagesessen.hours.dayLabel}</th>
              <th class="py-4 px-4 font-display text-primary text-lg">{t.tagesessen.hours.timeLabel}</th>
            </tr>
          </thead>
          <tbody class="font-body">
            {openingHours.map((row) => (
              <tr class="border-b border-primary/10">
                <td class="py-3 px-4 text-primary">{row.day}</td>
                <td class="py-3 px-4 text-secondary">{row.time}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      
      <div class="mt-6 p-4 bg-primary/10 rounded-lg">
        <p class="font-body text-secondary text-center">
          <strong class="text-primary">{t.tagesessen.hours.note}</strong>
        </p>
      </div>
      
      <p class="mt-4 text-center font-body text-primary text-sm">
        {t.tagesessen.hours.subjectToChange}
      </p>
    </div>
  </Section>

  <!-- Closed Dates Section -->
  <Section background="surface" padding="medium">
    <div class="max-w-2xl mx-auto text-center">
      <h3 class="font-display text-2xl font-bold text-primary mb-4">
        {t.tagesessen.closed.title}
      </h3>
      <div class="p-6 bg-primary/15 rounded-lg">
        <p class="font-body text-primary text-lg">
          {t.tagesessen.closed.text}
        </p>
      </div>
    </div>
  </Section>

  <!-- Contact Section -->
  <Section background="white" padding="large">
    <div class="text-center max-w-2xl mx-auto">
      <h3 class="font-display text-3xl font-bold text-primary mb-6">
        {t.tagesessen.contact.title}
      </h3>
      <div class="p-8 bg-background rounded-xl shadow-lg border border-primary/20">
        <p class="font-body text-secondary text-xl">
          <strong class="text-primary">{t.tagesessen.contact.phone}</strong>
        </p>
      </div>
    </div>
  </Section>

  <!-- Quick Links Section -->
  <Section background="background" padding="medium">
    <div class="flex flex-wrap justify-center gap-6">
      <a 
        href="/aktionskalender" 
        class="inline-block px-6 py-3 bg-primary hover:bg-primary-light text-white font-semibold rounded-md transition-all duration-300 shadow-lg hover:shadow-xl"
      >
        → {t.tagesessen.links.menu}
      </a>
      <a 
        href="/impressum" 
        class="inline-block px-6 py-3 border-2 border-primary hover:bg-primary hover:text-white text-primary font-semibold rounded-md transition-all duration-300"
      >
        → {t.tagesessen.links.imprint}
      </a>
      <a 
        href="/datenschutz" 
        class="inline-block px-6 py-3 border-2 border-primary hover:bg-primary hover:text-white text-primary font-semibold rounded-md transition-all duration-300"
      >
        → {t.tagesessen.links.privacy}
      </a>
    </div>
  </Section>
</Layout>
