---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';

const title = "Speisekarte - Menu | Vogthof Landgasthof";
const description = "Vogthof Landgasthof Menu / Speisekarte";
---

<Layout title={title} description={description}>
  <!-- Hero Section -->
  <Hero
    backgroundImage="/images/Aktionskalender.jpg"
    headline="Speisekarte"
    subheadline="Seasonal menu and calendar at Vogthof Landgasthof"
    ctaText="Download Menu"
    ctaLink="https://www.aalen-vogthof.de/aktionen/Aktionskalender.pdf"
    height="medium"
  />

  <!-- Menu Image Section -->
  <Section background="cream" padding="medium">
    <div class="flex flex-col items-center">
      <a 
        href="https://www.aalen-vogthof.de/aktionen/Aktionskalender.pdf" 
        target="_blank" 
        rel="noopener noreferrer"
        class="inline-block mb-6 group"
      >
        <img 
          src="/images/Aktionskalender.jpg" 
          alt="Menu Calendar"
          class="w-full max-w-2xl rounded-lg shadow-xl transition-transform duration-300 group-hover:scale-[1.02]"
        />
      </a>
      <p class="text-text-secondary font-body text-center">
        Möchten Sie die Liste herunterladen, dann klicken Sie bitte auf das Bild.<br/>
        <span class="text-sm">(Click on the image to download the menu)</span>
      </p>
    </div>
  </Section>

  <!-- Seasonal Information Section -->
  <Section 
    title="Saisonale Highlights" 
    subtitle="Seasonal Highlights"
    background="cream-dark"
    padding="medium"
  >
    <div class="max-w-4xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="p-6 bg-white rounded-xl shadow-lg border border-primary/10">
          <div class="flex items-center mb-4">
            <span class="text-3xl mr-3">🍃</span>
            <h4 class="font-display text-xl font-bold text-text-primary">
              Frühlingsgerichte
            </h4>
          </div>
          <p class="font-body text-text-secondary">
            Fresh spring dishes with seasonal vegetables and herbs.
          </p>
        </div>
        
        <div class="p-6 bg-white rounded-xl shadow-lg border border-primary/10">
          <div class="flex items-center mb-4">
            <span class="text-3xl mr-3">☀️</span>
            <h4 class="font-display text-xl font-bold text-text-primary">
              Sommerklassiker
            </h4>
          </div>
          <p class="font-body text-text-secondary">
            Classic summer favorites with fresh, light ingredients.
          </p>
        </div>
        
        <div class="p-6 bg-white rounded-xl shadow-lg border border-primary/10">
          <div class="flex items-center mb-4">
            <span class="text-3xl mr-3">🍂</span>
            <h4 class="font-display text-xl font-bold text-text-primary">
              Herbstliche Spezialitäten
            </h4>
          </div>
          <p class="font-body text-text-secondary">
            Autumn specialties with regional mushrooms and game.
          </p>
        </div>
        
        <div class="p-6 bg-white rounded-xl shadow-lg border border-primary/10">
          <div class="flex items-center mb-4">
            <span class="text-3xl mr-3">❄️</span>
            <h4 class="font-display text-xl font-bold text-text-primary">
              Wintergenüsse
            </h4>
          </div>
          <p class="font-body text-text-secondary">
            Comforting winter dishes with seasonal ingredients.
          </p>
        </div>
      </div>
    </div>
  </Section>

  <!-- Opening Hours Section -->
  <Section 
    title="Öffnungszeiten" 
    subtitle="Opening Hours"
    background="linen"
    padding="medium"
    id="hours"
  >
    <div class="max-w-3xl mx-auto">
      <div class="overflow-x-auto">
        <table class="w-full min-w-[300px] text-left">
          <thead>
            <tr class="border-b border-primary/30">
              <th class="py-4 px-4 font-display text-text-primary text-lg">Day</th>
              <th class="py-4 px-4 font-display text-text-primary text-lg">Time</th>
            </tr>
          </thead>
          <tbody class="font-body">
            <tr class="border-b border-primary/10">
              <td class="py-3 px-4 text-text-primary">Montag-Donnerstag</td>
              <td class="py-3 px-4 text-text-secondary">11:30-14 Uhr</td>
            </tr>
            <tr class="border-b border-primary/10">
              <td class="py-3 px-4 text-text-primary">Montag-Mittwoch</td>
              <td class="py-3 px-4 text-text-secondary">18:00-22 Uhr</td>
            </tr>
            <tr class="border-b border-primary/10">
              <td class="py-3 px-4 text-text-primary">Freitag</td>
              <td class="py-3 px-4 text-primary font-semibold">Ruhetag (Closed)</td>
            </tr>
            <tr class="border-b border-primary/10">
              <td class="py-3 px-4 text-text-primary">Samstag</td>
              <td class="py-3 px-4 text-text-secondary">18:00-22 Uhr</td>
            </tr>
            <tr class="border-b border-primary/10">
              <td class="py-3 px-4 text-text-primary">Sonntag</td>
              <td class="py-3 px-4 text-text-secondary">11:30-14 Uhr</td>
            </tr>
          </tbody>
        </table>
      </div>
      
      <div class="mt-6 p-4 bg-primary/10 rounded-lg">
        <p class="font-body text-text-secondary text-center">
          <strong class="text-text-primary">Sonn- und Feiertage Abends geschlossen!</strong><br/>
          <span class="text-sm italic">(Sunday and public holidays evenings closed!)</span>
        </p>
      </div>
      
      <p class="mt-4 text-center font-body text-primary text-sm">
        Änderungen vorbehalten <span class="italic">(Subject to changes)</span>
      </p>
    </div>
  </Section>

  <!-- Closed Dates Section -->
  <Section background="cream" padding="medium">
    <div class="max-w-2xl mx-auto text-center">
      <h3 class="font-display text-2xl font-bold text-text-primary mb-4">
        Geschlossen / Closed
      </h3>
      <div class="p-6 bg-primary/15 rounded-lg">
        <p class="font-body text-text-primary text-lg">
          Dienstag 31.03. abends- und Mittwoch 01.04. bis einschließlich 05.04.2026 geschlossen.
        </p>
      </div>
    </div>
  </Section>

  <!-- Contact Section -->
  <Section background="white" padding="large">
    <div class="text-center max-w-2xl mx-auto">
      <h3 class="font-display text-3xl font-bold text-text-primary mb-6">
        Kontakt / Contact
      </h3>
      <div class="p-8 bg-cream rounded-xl shadow-lg border border-primary/20">
        <p class="font-body text-text-secondary text-xl">
          <strong class="text-text-primary">Telefon:</strong> 07361-73688
        </p>
      </div>
    </div>
  </Section>

  <!-- Quick Links Section -->
  <Section background="cream-dark" padding="medium">
    <div class="flex flex-wrap justify-center gap-6">
      <a 
        href="/tagesessen" 
        class="inline-block px-6 py-3 bg-primary hover:bg-brand-light text-white font-semibold rounded-md transition-all duration-300 shadow-lg hover:shadow-xl"
      >
        → Tagesessen (Daily Specials)
      </a>
      <a 
        href="/impressum" 
        class="inline-block px-6 py-3 border-2 border-primary hover:bg-primary hover:text-white text-primary font-semibold rounded-md transition-all duration-300"
      >
        → Impressum (Legal)
      </a>
      <a 
        href="/datenschutz" 
        class="inline-block px-6 py-3 border-2 border-primary hover:bg-primary hover:text-white text-primary font-semibold rounded-md transition-all duration-300"
      >
        → Datenschutz (Privacy)
      </a>
    </div>
  </Section>
</Layout>
