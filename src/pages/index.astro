---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
---

<Layout title="Landgasthof Vogthof - Hotel & Restaurant in Aalen">
  <!-- Hero Section -->
  <Hero
    headline="Landgasthof Vogthof"
    subheadline="Traditional Swabian hospitality since 1983. Experience comfort, cuisine, and warm welcomes in the heart of Aalen-Röthardt."
    backgroundImage="/images/hotel1.jpg"
    ctaText="Explore Our Rooms"
    ctaLink="/rooms"
    ctaSecondaryText="View Menu"
    ctaSecondaryLink="/menus"
    height="large"
  />

  <!-- Introduction Section -->
  <Section
    title="Welcome to Vogthof"
    subtitle="Family-run with passion and tradition"
    background="cream"
  >
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-lg text-text-secondary leading-relaxed mb-6">
        The Landgasthof Vogthof was opened in 1983 by Hans and Theresia Ilg and has been run by their son Reiner and his wife Bernadette since 2012.
      </p>
      <p class="text-lg text-text-secondary leading-relaxed">
        True to the motto <span class="italic">"Der Gast ist König"</span> (The guest is king), the Ilg family and their team will spoil you with first-class dishes, fine wines, and comfortable accommodations.
      </p>
    </div>
  </Section>

  <!-- Featured Offerings -->
  <Section
    title="Discover Vogthof"
    subtitle="Your home away from home in the Ostalb region"
    background="cream-dark"
  >
    <div class="grid md:grid-cols-3 gap-8">
      <Card
        title="Comfortable Rooms"
        description="Our 3-star hotel rooms were renovated in 2014 with modern country-style furnishings. Perfect for relaxation after a long day."
        image="/images/rooms/z1.jpg"
        link="/rooms"
        linkText="View Rooms"
        hoverEffect="lift"
      />
      <Card
        title="Excellent Cuisine"
        description="Experience elegant Swabian cuisine with international accents. Our chefs create daily specials with regional ingredients."
        image="/images/eat/k1.jpg"
        link="/restaurant"
        linkText="Our Restaurant"
        hoverEffect="lift"
      />
      <Card
        title="Perfect for Events"
        description="Host your celebrations with us! We offer private rooms for intimate gatherings and space for up to 80 guests."
        image="/images/f1.jpg"
        link="/events"
        linkText="Plan Your Event"
        hoverEffect="lift"
      />
    </div>
  </Section>

  <!-- Restaurant Preview -->
  <Section
    title="Culinary Delights"
    subtitle="Traditional Swabian hospitality meets modern cuisine"
    background="linen"
  >
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div class="relative">
        <img
          src="/images/restaurant/r1.jpg"
          alt="Restaurant Vogthof"
          class="rounded-lg shadow-xl w-full"
        />
      </div>
      <div class="prose prose-lg text-text-secondary">
        <p class="mb-6">
          Our kitchen team, led by Reiner Ilg and Johannes Hänle, serves elegant Swabian cuisine with international accents. We attach great importance to ingredients from the region.
        </p>
        <p class="mb-6">
          Whether you're joining us for a quick lunch, a romantic dinner, or a family celebration – we look forward to welcoming you.
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href="/menus"
            class="inline-block px-6 py-3 bg-primary hover:bg-brand-light text-white font-semibold rounded-lg transition-all duration-300"
          >
            View Menu
          </a>
          <a
            href="/restaurant"
            class="inline-block px-6 py-3 border-2 border-primary text-primary hover:bg-primary hover:text-white font-semibold rounded-lg transition-all duration-300"
          >
            About Our Restaurant
          </a>
        </div>
      </div>
    </div>
  </Section>

  <!-- Activities Preview -->
  <Section
    title="Explore the Region"
    subtitle="Adventure, wellness, and culture await"
    background="cream"
  >
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      <div class="bg-white rounded-lg p-6 shadow-md text-center">
        <div class="text-4xl mb-4">🥾</div>
        <h3 class="font-display text-lg font-bold text-text-primary mb-2">
          Hiking
        </h3>
        <p class="text-sm text-text-secondary">
          Explore the beautiful natural landscape around Braunenberg on the Ostalb.
        </p>
      </div>
      <div class="bg-white rounded-lg p-6 shadow-md text-center">
        <div class="text-4xl mb-4">🚴</div>
        <h3 class="font-display text-lg font-bold text-text-primary mb-2">
          Cycling
        </h3>
        <p class="text-sm text-text-secondary">
          Discover perfect trails for cycling enthusiasts of all levels.
        </p>
      </div>
      <div class="bg-white rounded-lg p-6 shadow-md text-center">
        <div class="text-4xl mb-4">♨️</div>
        <h3 class="font-display text-lg font-bold text-text-primary mb-2">
          Wellness
        </h3>
        <p class="text-sm text-text-secondary">
          Relax at the Limes Thermen thermal baths, just 10 minutes away.
        </p>
      </div>
      <div class="bg-white rounded-lg p-6 shadow-md text-center">
        <div class="text-4xl mb-4">🏛️</div>
        <h3 class="font-display text-lg font-bold text-text-primary mb-2">
          Culture
        </h3>
        <p class="text-sm text-text-secondary">
          Visit historic towns like Aalen, Ellwangen, and Neresheim.
        </p>
      </div>
    </div>
    <div class="text-center mt-8">
      <a
        href="/activities"
        class="inline-block px-8 py-4 bg-secondary hover:bg-forest-light text-white font-semibold rounded-lg transition-all duration-300"
      >
        Discover All Activities
      </a>
    </div>
  </Section>

  <!-- Contact CTA -->
  <Section
    title="Visit Us"
    subtitle="We look forward to welcoming you"
    background="cream-dark"
  >
    <div class="max-w-4xl mx-auto">
      <div class="grid md:grid-cols-3 gap-8 mb-8">
        <div class="bg-white p-6 rounded-lg shadow-md text-center">
          <h3 class="font-bold text-text-primary mb-2">📍 Address</h3>
          <p class="text-text-secondary text-sm">
            Bergbaustraße 28/1<br />
            73433 Aalen-Röthardt
          </p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-md text-center">
          <h3 class="font-bold text-text-primary mb-2">📞 Phone</h3>
          <p class="text-text-secondary text-sm">
            <a href="tel:07361-73688" class="hover:text-primary">
              07361-73688
            </a>
          </p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow-md text-center">
          <h3 class="font-bold text-text-primary mb-2">✉️ Email</h3>
          <p class="text-text-secondary text-sm">
            <a href="mailto:info@aalen-vogthof.de" class="hover:text-primary">
              info@aalen-vogthof.de
            </a>
          </p>
        </div>
      </div>
      <div class="text-center">
        <a
          href="/contact"
          class="inline-block px-8 py-4 bg-primary hover:bg-brand-light text-white font-semibold rounded-lg transition-all duration-300 shadow-lg hover:shadow-xl"
        >
          Get in Touch
        </a>
      </div>
    </div>
  </Section>
</Layout>
