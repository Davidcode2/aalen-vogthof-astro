---
interface Props {
  submitUrl?: string;
  buttonText?: string;
}

const {
  submitUrl = '/api/contact',
  buttonText = 'Send Message'
} = Astro.props;
---

<form class="bg-white rounded-xl shadow-lg p-6 md:p-8" action={submitUrl} method="POST">
  <!-- Form Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
    <!-- Name Field -->
    <div class="space-y-2">
      <label for="name" class="block font-['Open_Sans',Arial,sans-serif] text-sm font-semibold text-[#2C1810]">
        Name *
      </label>
      <input
        type="text"
        id="name"
        name="name"
        required
        placeholder="Your full name"
        class="w-full px-4 py-3 border border-[#D4A574] rounded-lg focus:outline-none focus:ring-2 focus:ring-[#8B4513] focus:border-transparent font-['Open_Sans',Arial,sans-serif] transition-all duration-300"
      />
    </div>

    <!-- Email Field -->
    <div class="space-y-2">
      <label for="email" class="block font-['Open_Sans',Arial,sans-serif] text-sm font-semibold text-[#2C1810]">
        Email *
      </label>
      <input
        type="email"
        id="email"
        name="email"
        required
        placeholder="your@email.com"
        class="w-full px-4 py-3 border border-[#D4A574] rounded-lg focus:outline-none focus:ring-2 focus:ring-[#8B4513] focus:border-transparent font-['Open_Sans',Arial,sans-serif] transition-all duration-300"
      />
    </div>

    <!-- Phone Field -->
    <div class="space-y-2 md:col-span-2">
      <label for="phone" class="block font-['Open_Sans',Arial,sans-serif] text-sm font-semibold text-[#2C1810]">
        Phone Number
      </label>
      <input
        type="tel"
        id="phone"
        name="phone"
        placeholder="+49 (optional)"
        class="w-full px-4 py-3 border border-[#D4A574] rounded-lg focus:outline-none focus:ring-2 focus:ring-[#8B4513] focus:border-transparent font-['Open_Sans',Arial,sans-serif] transition-all duration-300"
      />
    </div>
  </div>

  <!-- Message Field -->
  <div class="space-y-2 mb-6">
    <label for="message" class="block font-['Open_Sans',Arial,sans-serif] text-sm font-semibold text-[#2C1810]">
      Message *
    </label>
    <textarea
      id="message"
      name="message"
      required
      rows="5"
      placeholder="How can we help you?"
      class="w-full px-4 py-3 border border-[#D4A574] rounded-lg focus:outline-none focus:ring-2 focus:ring-[#8B4513] focus:border-transparent font-['Open_Sans',Arial,sans-serif] transition-all duration-300 resize-none"
    ></textarea>
  </div>

  <!-- GDPR Consent -->
  <div class="flex items-start gap-3 mb-8">
    <input
      type="checkbox"
      id="gdpr"
      name="gdpr"
      required
      class="mt-1 w-5 h-5 text-[#8B4513] border-[#D4A574] rounded focus:ring-[#8B4513] cursor-pointer"
    />
    <label for="gdpr" class="font-['Open_Sans',Arial,sans-serif] text-sm text-[#5C4033] leading-relaxed">
      I agree to the processing of my personal data in accordance with the <a href="/privacy" class="text-[#8B4513] hover:text-[#2D5A27] underline">Privacy Policy</a>. This is required to respond to your inquiry. *
    </label>
  </div>

  <!-- Submit Button -->
  <div class="text-center">
    <button
      type="submit"
      class="inline-block px-8 py-4 bg-[#8B4513] hover:bg-[#2D5A27] text-white font-semibold rounded-lg shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-0.5"
    >
      {buttonText}
    </button>
  </div>

  <!-- Success Message (hidden by default) -->
  <div id="form-success" class="hidden mt-4 p-4 bg-green-50 border border-green-200 rounded-lg">
    <p class="text-green-800 text-center font-['Open_Sans',Arial,sans-serif]">
      Thank you for your message! We will get back to you soon.
    </p>
  </div>
</form>